import {
    MaterialStyleMetrics,
    MaterialTypography,
    FilledButton,
    FilledCard,
    MaterialText,
    Vertical,
} from "../material/material.slint";

// ============================================================================
// InputFileCard Component
// ============================================================================
/// This component provides the entry point for users to load a file.
/// 
/// C++ Binding Architecture:
/// - Exposes the `browse_file()` callback, which maps to 
///   `AppController::handleBrowseFile()` in C++.
/// - When clicked, the C++ backend opens a native file dialog (via 
///   `PortableFileDialogs`) to select the input structure/trajectory.
// ============================================================================
export component InputFileCard inherits FilledCard {
    callback browse_file();

    // Export hover state for tooltip
    out property <string> hovered_tooltip_text: root.enabled && file_area.has-hover ? "Load a structure file" : "";
    in property <bool> enabled: true;

    Vertical {
        MaterialText {
            text: "Input File";
            style: MaterialTypography.title_small;
        }

        file_area := TouchArea {
            min-height: 40px;
            FilledButton {
                enabled: root.enabled;
                height: 40px;
                width: 100%;
                text: "Load file";
                clicked => {
                    root.browse_file();
                }
            }
        }
    }
}
