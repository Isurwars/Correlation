import {
    MaterialStyleMetrics,
    MaterialPalette,
    FilledCard,
    ExpandableHeader,
    TextField,
    DropDownMenu,
    Vertical,
    CheckBoxRow,
} from "../material/material.slint";

export component SmoothingOptionsCard inherits FilledCard {
    in-out property <bool> expanded: false;
    in property <bool> file_loaded;
    in-out property <bool> smoothing_enabled;
    in-out property <string> smoothing_sigma;
    in-out property <int> smoothing_kernel;
    in property <string> smoothing_sigma_error: "";

    out property <string> hovered_tooltip_text:
        sigma_area.has-hover ? "Standard deviation (σ) for the smoothing kernel.\n\n📏 Recommended: 0.01 Å.\n\n🔬 Physics: Controls the width of the convolution kernel applied to distribution functions. Larger σ smooths more noise but broadens real peaks — important for resolving the first g(r) peak. As a rule of thumb, σ should be comparable to or smaller than the bin width to avoid over-smoothing physical features." : kernel_area.has-hover ? "Type of smoothing kernel applied to distribution functions.\n\n🔬 Gaussian: Standard choice — smooth, infinite support. Best for general-purpose smoothing.\n\n🔬 Bump: Compact support with a sharp cutoff. Preserves high-frequency features better than Gaussian — use for crystalline systems with sharp peaks.\n\n🔬 Triweight: Compact support with higher weight near the center. Good for noisy data from small simulation cells, as it suppresses outliers more aggressively." : "";

    Vertical {

        ExpandableHeader {
            text: "Smoothing";
            expanded <=> root.expanded;
        }

        Vertical {
            height: root.expanded ? self.preferred-height : 0px;
            visible: self.height > 0px;
            opacity: root.expanded ? 1.0 : 0.0;
            animate height, opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_4;

            CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.smoothing_enabled;
                text: "Enable Smoothing";
                checked_state_changed(s) => {
                    root.smoothing_enabled = s;
                }
            }

            sigma_area := TouchArea {
                TextField {
                    enabled: root.file_loaded && root.smoothing_enabled;
                    width: 100%;
                    label: "Smoothing Sigma";
                    text <=> root.smoothing_sigma;
                    has_error: root.smoothing_sigma_error != "";
                    supporting_text: root.smoothing_sigma_error;
                }
            }

            kernel_area := TouchArea {
                DropDownMenu {
                    enabled: root.file_loaded && root.smoothing_enabled;
                    width: 100%;
                    label: "Smoothing Kernel";
                    items: [
                        { text: "Gaussian", enabled: true },
                        { text: "Bump", enabled: true },
                        { text: "Triweight", enabled: true }
                    ];
                    current-index <=> root.smoothing_kernel;
                }
            }
        }
    }
}
