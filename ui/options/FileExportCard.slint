import {
    MaterialStyleMetrics,
    MaterialTypography,
    MaterialPalette,
    FilledCard,
    MaterialText,
    Vertical,
    CheckBoxRow,
} from "../material/material.slint";

// ============================================================================
// FileExportCard Component
// ============================================================================
/// Provides checkboxes to choose output file format types (CSV, HDF5, Parquet)
/// for saving analysis computations.
// ============================================================================
export component FileExportCard inherits FilledCard {
    in property <bool> file_loaded;
    in property <bool> hdf5_available: true;
    in property <bool> parquet_available: true;
    
    in-out property <bool> use_csv: true;
    in-out property <bool> use_hdf5: false;
    in-out property <bool> use_parquet: false;

    out property <string> hovered_tooltip_text:
        csv_area.has-hover ? "Export results as CSV (Comma-Separated Values) files.\n\n📏 Best for: Quick plotting in Excel, gnuplot, or Python (pandas.read_csv). One file per distribution function.\n\n💡 Tip: CSV is universally compatible and human-readable — good for sharing results and debugging." : 
        hdf5_area.has-hover ? "Export results to a single HDF5 binary file.\n\n📏 Best for: Large datasets, Python (h5py) and MATLAB workflows. All results in one structured file.\n\n💡 Tip: HDF5 preserves metadata and is more compact than CSV for multi-frame trajectories." : 
        parquet_area.has-hover ? "Export results as Apache Parquet files.\n\n📏 Best for: Columnar data analytics, Python (pandas/pyarrow), and integration with data science pipelines.\n\n💡 Tip: Parquet offers excellent compression and fast column-wise reads for large datasets." : "";

    Vertical {
        spacing: MaterialStyleMetrics.spacing_12;
        padding: MaterialStyleMetrics.spacing_12;

        MaterialText {
            text: "File Export Formats";
            style: MaterialTypography.label_large;
            color: MaterialPalette.on_surface_variant;
        }

        Vertical {
            spacing: MaterialStyleMetrics.spacing_4;

            csv_area := CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.use_csv;
                text: "Export as CSV";
                checked_state_changed(s) => {
                    root.use_csv = s;
                }
            }

            hdf5_area := CheckBoxRow {
                enabled: root.file_loaded && root.hdf5_available;
                check_state_bool: root.use_hdf5;
                text: "Export as HDF5";
                checked_state_changed(s) => {
                    root.use_hdf5 = s;
                }
            }

            parquet_area := CheckBoxRow {
                enabled: root.file_loaded && root.parquet_available;
                check_state_bool: root.use_parquet;
                text: "Export as Parquet";
                checked_state_changed(s) => {
                    root.use_parquet = s;
                }
            }
        }
    }
}
