import {
    MaterialStyleMetrics,
    MaterialPalette,
    FilledCard,
    ExpandableHeader,
    TextField,
    Vertical,
} from "../material/material.slint";

export component RingsOptionsCard inherits FilledCard {
    in-out property <bool> expanded: false;
    in property <bool> file_loaded;
    in-out property <string> max_ring_size;
    in property <string> max_ring_error: "";

    out property <string> hovered_tooltip_text:
        ring_size_area.has-hover ? "Maximum ring size for topological ring statistics.\n\n📏 Recommended: 8–12 (default: 12).\n\n🔬 Physics: Rings are closed loops of bonded atoms — they characterize medium-range order in network glasses (e.g., SiO₂ has predominantly 6-membered rings). Larger max sizes capture rare large rings but increase computation time exponentially. For most amorphous networks, rings >12 are statistically rare and computationally expensive." : "";

    Vertical {

        ExpandableHeader {
            text: "Topological Rings";
            expanded <=> root.expanded;
        }

        Vertical {
            height: root.expanded ? self.preferred-height : 0px;
            visible: self.height > 0px;
            opacity: root.expanded ? 1.0 : 0.0;
            animate height, opacity {
                duration: 250ms;
                easing: ease-in-out;
            }

            ring_size_area := TouchArea {
                TextField {
                    enabled: root.file_loaded;
                    width: 100%;
                    label: "Max Ring Size";
                    text <=> root.max_ring_size;
                    has_error: root.max_ring_error != "";
                    supporting_text: root.max_ring_error;
                }
            }
        }
    }
}
