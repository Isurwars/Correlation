import {
    MaterialStyleMetrics,
    MaterialTypography,
    MaterialPalette,
    FilledCard,
    MaterialText,
    TextField,
    Vertical,
    Horizontal,
} from "../material/material.slint";

// ============================================================================
// TrajectoryOptionsCard Component
// ============================================================================
/// Allows users to specify trajectory analysis configurations, specifically
/// the time step (fs) and range of frames (Start and End) to be analyzed.
// ============================================================================
export component TrajectoryOptionsCard inherits FilledCard {
    in property <bool> file_loaded;
    in property <int> num_frames;

    in-out property <string> time_step;
    in property <string> time_step_error: "";

    in-out property <string> min_frame;
    in-out property <string> max_frame;
    in property <string> min_frame_error: "";
    in property <string> max_frame_error: "";

    out property <string> hovered_tooltip_text:
        time_step_area.has-hover ? "Time interval between parsed frames in femtoseconds (fs).\n\n📏 Auto-calculated from atomic masses using √(9m/5), where m is the lightest element's mass.\n\n🔬 Physics: The time step determines the time axis for dynamic properties (MSD, VACF, vDoS). Verify this matches your simulation's actual time step for accurate diffusion coefficients and vibrational spectra." :
        start_frame_area.has-hover ? "First frame to include in the analysis.\n\n📏 Tip: Use 'Start' or '1' for the first frame.\n\n🔬 Physics: In molecular dynamics, the initial frames may represent an equilibration phase. Excluding early frames ensures only the production run is analyzed. A common practice is to discard the first 10–20% of frames." :
        end_frame_area.has-hover ? "Last frame to include in the analysis.\n\n📏 Tip: Use 'End' to include all remaining frames.\n\n🔬 Physics: Selecting a subset of frames can speed up analysis during parameter exploration. Once you find good settings, use the full range for publication-quality results." : "";

    out property <length> hovered_x:
        time_step_area.has-hover ? time_step_area.absolute-position.x :
        start_frame_area.has-hover ? start_frame_area.absolute-position.x :
        end_frame_area.has-hover ? end_frame_area.absolute-position.x : 0px;
    out property <length> hovered_y:
        time_step_area.has-hover ? time_step_area.absolute-position.y :
        start_frame_area.has-hover ? start_frame_area.absolute-position.y :
        end_frame_area.has-hover ? end_frame_area.absolute-position.y : 0px;
    out property <length> hovered_width:
        time_step_area.has-hover ? time_step_area.width :
        start_frame_area.has-hover ? start_frame_area.width :
        end_frame_area.has-hover ? end_frame_area.width : 0px;
    out property <length> hovered_height:
        time_step_area.has-hover ? time_step_area.height :
        start_frame_area.has-hover ? start_frame_area.height :
        end_frame_area.has-hover ? end_frame_area.height : 0px;

    Vertical {
        spacing: MaterialStyleMetrics.spacing_12;
        padding: MaterialStyleMetrics.spacing_12;

        MaterialText {
            text: "Trajectory Options";
            style: MaterialTypography.label_large;
            color: MaterialPalette.on_surface_variant;
        }

        // Time Step input
        time_step_area := TouchArea {
            Horizontal {
                TextField {
                    label: "Time Step (fs)";
                    horizontal-stretch: 1;
                    vertical-stretch: 0;
                    text <=> root.time_step;
                    enabled: root.file_loaded && root.num_frames > 1;
                    has_error: root.time_step_error != "";
                    supporting_text: root.time_step_error;
                }
            }
        }

        // Frame Range inputs
        Vertical {
            spacing: MaterialStyleMetrics.spacing_4;
            MaterialText {
                text: "Frame Range (Total: " + root.num_frames + ")";
                style: MaterialTypography.body_small;
                color: MaterialPalette.on_surface_variant;
            }

            Horizontal {
                spacing: MaterialStyleMetrics.spacing_8;

                start_frame_area := TouchArea {
                    horizontal-stretch: 1;
                    TextField {
                        enabled: root.file_loaded && root.num_frames > 1;
                        width: 100%;
                        label: "Start Frame";
                        text <=> root.min_frame;
                        has_error: root.min_frame_error != "";
                        supporting_text: root.min_frame_error;
                    }
                }

                end_frame_area := TouchArea {
                    horizontal-stretch: 1;
                    TextField {
                        enabled: root.file_loaded && root.num_frames > 1;
                        width: 100%;
                        label: "End Frame";
                        text <=> root.max_frame;
                        has_error: root.max_frame_error != "";
                        supporting_text: root.max_frame_error;
                    }
                }
            }
        }
    }
}
