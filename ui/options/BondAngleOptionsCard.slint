import {
    MaterialStyleMetrics,
    MaterialPalette,
    FilledCard,
    ExpandableHeader,
    TextField,
    Vertical,
} from "../material/material.slint";

export component BondAngleOptionsCard inherits FilledCard {
    in-out property <bool> expanded: true;
    in property <bool> file_loaded;
    in-out property <string> angle_bin_width;
    in-out property <string> dihedral_bin_width;
    in property <string> angle_bin_error: "";
    in property <string> dihedral_bin_error: "";

    out property <string> hovered_tooltip_text:
        theta_bin_area.has-hover ? "Bin width for the Plane-Angle Distribution (PAD).\n\n📏 Recommended: 1.0°.\n\n🔬 Physics: The PAD measures bond angles between triplets of bonded atoms (e.g., O–Si–O ≈ 109.5° in tetrahedral coordination). 1° resolves distinct coordination geometries while maintaining good statistics. Finer bins (0.5°) help for crystalline systems with sharp angular peaks." : dihedral_bin_area.has-hover ? "Bin width for the Dihedral-Angle Distribution (DAD).\n\n📏 Recommended: 1.0°.\n\n🔬 Physics: Dihedral angles measure torsion across four-atom chains (A–B–C–D). They reveal rotational conformations and ring puckering. 1° is sufficient for most amorphous systems; use finer bins for molecular crystals with distinct torsional states." : "";

    Vertical {

        ExpandableHeader {
            text: "Bond Angle";
            expanded <=> root.expanded;
        }

        Vertical {
            height: root.expanded ? self.preferred-height : 0px;
            visible: self.height > 0px;
            opacity: root.expanded ? 1.0 : 0.0;
            animate height, opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_8;
            padding-left: MaterialStyleMetrics.spacing_8;

            theta_bin_area := TouchArea {
                width: 100%;
                TextField {
                    enabled: root.file_loaded;
                    width: 100%;
                    label: "PAD Bin Width (°)";
                    text <=> root.angle_bin_width;
                    has_error: root.angle_bin_error != "";
                    supporting_text: root.angle_bin_error;
                }
            }

            dihedral_bin_area := TouchArea {
                width: 100%;
                TextField {
                    enabled: root.file_loaded;
                    width: 100%;
                    label: "DAD Bin Width (°)";
                    text <=> root.dihedral_bin_width;
                    has_error: root.dihedral_bin_error != "";
                    supporting_text: root.dihedral_bin_error;
                }
            }
        }
    }
}
