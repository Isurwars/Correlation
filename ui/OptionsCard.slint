import {
    MaterialStyleMetrics,
    MaterialTypography,
    CheckBox,
    CheckState,
    TextField,
    DropDownMenu,
    FilledCard,
    MaterialText,
    Icon,
    Icons,
    MaterialPalette,
    ScrollView,
    ExpandableHeader,
    CheckBoxRow,
} from "@material";
import { BondCutoff } from "Types.slint";

// ============================================================================
// OptionsCard Component
// ============================================================================
// This component encapsulates the configuration inputs for the analysis (e.g.,
// RDF max r, S(Q) max Q, smoothing options, and bond cutoffs).
// 
// C++ Binding Architecture:
// - The properties defined here (like `r_max`, `smoothing_sigma`) are bound
//   bi-directionally to the `AppWindow` root component.
// - The C++ controller (`AppController::handleOptionsfromUI`) reads these values
//   through the `AppWindow` instance when an analysis is started, parsing the 
//   strings into appropriate numeric types for the backend (`AppBackend`).
// - Conversely, when a file is loaded, the backend recommendations are pushed
//   back to the UI (via `AppController::handleOptionstoUI`), updating these
//   same properties to display default values.
// ============================================================================
export component OptionsCard inherits FilledCard {
    in-out property <string> r_max;
    in-out property <string> r_bin_width;
    in-out property <string> q_max;
    in-out property <string> q_bin_width;
    in-out property <string> r_int_max;
    in-out property <string> angle_bin_width;
    in-out property <string> dihedral_bin_width;
    in-out property <string> max_ring_size;
    in-out property <bool> smoothing: true;
    in-out property <bool> use_hdf5: true;
    in-out property <bool> use_csv: true;
    in-out property <string> smoothing_sigma;
    in-out property <int> smoothing_kernel;
    in-out property <[BondCutoff]> bond_cutoffs;
    in property <bool> file_loaded;
    in-out property <bool> run_rdf: true;
    in-out property <bool> run_sq: true;
    in-out property <bool> run_xrd: true;
    in-out property <bool> run_pad: true;
    in-out property <bool> run_dad: true;
    in-out property <bool> run_vacf: true;
    in-out property <bool> run_vdos: true;
    in-out property <bool> run_rd: true;
    in-out property <bool> rd_cb: true;
    in-out property <bool> vacf_cb: true;
    
    // Toggle stats for groups
    in-out property <bool> analyses_expanded: false;
    in-out property <bool> rdf_expanded: false;
    in-out property <bool> sq_expanded: false;
    in-out property <bool> angle_expanded: false;
    in-out property <bool> md_expanded: false;
    in-out property <bool> smoothing_expanded: false;
    in-out property <bool> bond_cutoffs_expanded: false;

    // Toggle height for groups
    property <length> analyses_height: analyses_expanded ? 320px : 0px;
    property <length> rdf_height: rdf_expanded ? 100px : 0px;
    property <length> sq_height: sq_expanded ? 150px : 0px;
    property <length> angle_height: angle_expanded ? 100px : 0px;
    property <length> md_height: md_expanded ? 50px : 0px;
    property <length> smoothing_height: smoothing_expanded ? 100px : 0px;
    property <length> bond_cutoffs_height: bond_cutoffs_expanded ? min(150px, root.bond_cutoffs.length * 50px) : 0px;
  
    // Hover states for tooltips
    out property <bool> r_max_has_hover: r_max_area.has-hover;
    out property <bool> r_bin_has_hover: r_bin_area.has-hover;
    out property <bool> q_max_has_hover: q_max_area.has-hover;
    out property <bool> r_int_has_hover: r_int_area.has-hover;
    out property <bool> theta_bin_has_hover: theta_bin_area.has-hover;
    out property <bool> dihedral_bin_has_hover: dihedral_bin_area.has-hover;
    out property <bool> ring_size_has_hover: ring_size_area.has-hover;
    out property <bool> q_bin_has_hover: q_bin_area.has-hover;

    out property <bool> sigma_has_hover: sigma_area.has-hover;
    out property <bool> kernel_has_hover: kernel_area.has-hover;

    out property <bool> rdf_cb_has_hover: rdf_cb_area.has-hover;
    out property <bool> sq_cb_has_hover: sq_cb_area.has-hover;
    out property <bool> xrd_cb_has_hover: xrd_cb_area.has-hover;
    out property <bool> pad_cb_has_hover: pad_cb_area.has-hover;
    out property <bool> dad_cb_has_hover: dad_cb_area.has-hover;
    out property <bool> vacf_cb_has_hover: vacf_cb_area.has-hover;
    out property <bool> vdos_cb_has_hover: vdos_cb_area.has-hover;
    out property <bool> rd_cb_has_hover: rd_cb_area.has-hover;

    VerticalLayout {
        padding: MaterialStyleMetrics.spacing_4;
        spacing: MaterialStyleMetrics.spacing_4;
        alignment: space-around;
        
        // 0. Select Analyses
        ExpandableHeader {
            text: "Select Analyses";
            expanded <=> root.analyses_expanded;
        }

        VerticalLayout {
            alignment: start;
            height: root.analyses_height;
            opacity: root.analyses_expanded ? 1.0 : 0.0;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_4;
            padding_left: MaterialStyleMetrics.spacing_8;

            MaterialText {
                text: "Structural";
                style: MaterialTypography.label_small;
                color: MaterialPalette.on_surface_variant;
            }

            rdf_cb_area := CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.run_rdf;
                text: "Radial Functions";
                checked_state_changed(s) => {
                    root.run_rdf = s;
                }
            }

            sq_cb_area := CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.run_sq;
                text: "Structure Factor";
                checked_state_changed(s) => {
                    root.run_sq = s;
                }
            }

            xrd_cb_area := CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.run_xrd;
                text: "XRD";
                checked_state_changed(s) => {
                    root.run_xrd = s;
                }
            }

            Rectangle {
                height: 1px;
                background: MaterialPalette.outline_variant;
            }

            MaterialText {
                text: "Angular";
                style: MaterialTypography.label_small;
                color: MaterialPalette.on_surface_variant;
            }

            pad_cb_area := CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.run_pad;
                text: "Plane-Angles";
                checked_state_changed(s) => {
                    root.run_pad = s;
                }
            }

            dad_cb_area := CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.run_dad;
                text: "Dihedral-Angles";
                checked_state_changed(s) => {
                    root.run_dad = s;
                }
            }

            Rectangle {
                height: 1px;
                background: MaterialPalette.outline_variant;
            }

            MaterialText {
                text: "Rings";
                style: MaterialTypography.label_small;
                color: MaterialPalette.on_surface_variant;
            }

            rd_cb_area := CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.rd_cb;
                text: "Ring Distribution";
                checked_state_changed(s) => {
                    root.rd_cb = s;
                }
            }

            Rectangle {
                height: 1px;
                background: MaterialPalette.outline_variant;
            }

            MaterialText {
                text: "Dynamic";
                style: MaterialTypography.label_small;
                color: MaterialPalette.on_surface_variant;
            }

            vacf_cb_area := CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.run_vacf;
                text: "Velocity-ACF";
                checked_state_changed(s) => {
                    root.run_vacf = s;
                }
            }

            vdos_cb_area := CheckBoxRow {
                enabled: root.file_loaded;
                check_state_bool: root.run_vdos;
                text: "vDoS";
                checked_state_changed(s) => {
                    root.run_vdos = s;
                }
            }
        }

        // 1. Radial Distribution Group
        ExpandableHeader {
            text: "Radial Distribution";
            expanded <=> root.rdf_expanded;
        }

        VerticalLayout {
            height: root.rdf_height;
            opacity: root.rdf_expanded ? 1.0 : 0.0;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_8;
            padding_left: MaterialStyleMetrics.spacing_8; // Indent content
            r_max_area := TouchArea {
                TextField {
                    width: 90%;
                    label: "RDF Max r (Å)";
                    text <=> root.r_max;
                }
            }

            r_bin_area := TouchArea {
                TextField {
                    width: 90%;
                    label: "RDF Bin Width (Å)";
                    text <=> root.r_bin_width;
                }
            }
        }

        // 2. Structure Factor Group
        ExpandableHeader {
            text: "Structure Factor";
            expanded <=> root.sq_expanded;
        }

        VerticalLayout {
            height: root.sq_height;
            opacity: root.sq_expanded ? 1.0 : 0.0;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_8;
            padding_left: MaterialStyleMetrics.spacing_8;
            q_max_area := TouchArea {
                TextField {
                    width: 90%;
                    label: "Max Q (Å⁻¹)";
                    text <=> root.q_max;
                }
            }

            q_bin_area := TouchArea {
                TextField {
                    width: 90%;
                    label: "S(Q) Bin Width (Å⁻¹)";
                    text <=> root.q_bin_width;
                }
            }

            r_int_area := TouchArea {
                TextField {
                    width: 90%;
                    label: "Max r for the FFT (Å)";
                    text <=> root.r_int_max;
                }
            }
        }

        // 3. Bond Angle Group
        ExpandableHeader {
            text: "Bond Angle";
            expanded <=> root.angle_expanded;
        }

        VerticalLayout {
            height: root.angle_height;
            opacity: root.angle_expanded ? 1.0 : 0.0;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_8;
            padding_left: MaterialStyleMetrics.spacing_8;
            theta_bin_area := TouchArea {
                TextField {
                    width: 90%;
                    label: "PAD Bin Width (°)";
                    text <=> root.angle_bin_width;
                }
            }

            dihedral_bin_area := TouchArea {
                TextField {
                    width: 90%;
                    label: "DAD Bin Width (°)";
                    text <=> root.dihedral_bin_width;
                }
            }
        }

        // 3.5 Topological Rings Group
        ExpandableHeader {
            text: "Topological Rings";
            expanded <=> root.md_expanded;
        }

        VerticalLayout {
            height: root.md_height;
            opacity: root.md_expanded ? 1.0 : 0.0;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_8;
            padding_left: MaterialStyleMetrics.spacing_8;
            ring_size_area := TouchArea {
                TextField {
                    width: 90%;
                    label: "Max Ring Size";
                    text <=> root.max_ring_size;
                }
            }
        }

        // 4. Smoothing Group
        ExpandableHeader {
            text: "Smoothing";
            expanded <=> root.smoothing_expanded;
        }

        VerticalLayout {
            height: root.smoothing_height;
            opacity: root.smoothing_expanded ? 1.0 : 0.0;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_8;
            padding_left: MaterialStyleMetrics.spacing_8;
            sigma_area := TouchArea {
                TextField {
                    width: 90%;
                    label: "Smoothing Sigma";
                    text <=> root.smoothing_sigma;
                }
            }

            kernel_area := TouchArea {
                DropDownMenu {
                    width: 90%;
                    label: "Smoothing Kernel";
                    items: [
                        { text: "Gaussian", enabled: true },
                        { text: "Bump", enabled: true },
                        { text: "Triweight", enabled: true }
                    ];
                    current-index <=> root.smoothing_kernel;
                }
            }
        }

        // 5. Bond Cutoffs Group
        ExpandableHeader {
            text: "Bond Cutoffs";
            expanded <=> root.bond_cutoffs_expanded;
        }

        VerticalLayout {
            height: root.bond_cutoffs_height;
            opacity: root.bond_cutoffs_expanded ? 1.0 : 0.0;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_8;
            padding_left: MaterialStyleMetrics.spacing_8;

            ScrollView {
                vertical-stretch: 0;
                height: min(list_layout.preferred-height, root.bond_cutoffs_height);
                viewport-height: list_layout.preferred-height;
                viewport-width: list_layout.preferred-width;
                list_layout := VerticalLayout {
                    spacing: MaterialStyleMetrics.spacing_4;
                    padding: MaterialStyleMetrics.padding_4;
                    for cutoff[i] in root.bond_cutoffs: HorizontalLayout {
                        alignment: center;
                        spacing: MaterialStyleMetrics.spacing_4;
                        MaterialText {
                            min-width: 75px;
                            text: cutoff.element1 + " - " + cutoff.element2 + ":";
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        TextField {
                            min-width: 95px;
                            text: cutoff.distance;
                            label: "Cutoff (Å)";
                            edited(s) => {
                                root.bond_cutoffs[i].distance = s;
                            }
                        }
                    }
                }
            }
        }
    }
}
