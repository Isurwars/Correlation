import {
    MaterialStyleMetrics,
    MaterialTypography,
    MaterialPalette,
    FilledCard,
    MaterialText,
    TextField,
    InfoRow,
} from "@material";
import { AtomCount } from "Types.slint";

export component FileInfoCard inherits FilledCard {
    visible: root.file_loaded;
    in-out property <string> file_status_text;
    in property <bool> file_loaded;
    in property <int> num_frames;
    in property <int> total_atoms;
    in property <int> removed_frames_count;
    in property <[AtomCount]> atom_counts;
    in-out property <string> time_step;

    out property <bool> frames_hover: frames_layout.has-hover;
    out property <bool> atoms_hover: atoms_layout.has-hover;
    out property <bool> removed_frames_hover: removed_layout.has-hover;
    out property <bool> time_step_hover: time_step_area.has-hover;

    height: root.file_loaded ? root.preferred-height : 0px;
    VerticalLayout {
        padding: MaterialStyleMetrics.spacing_8;
        spacing: MaterialStyleMetrics.spacing_4;
        VerticalLayout {
            spacing: MaterialStyleMetrics.spacing_4;

            MaterialText {
                text: root.file_status_text;
                horizontal-stretch: 1;
                wrap: word-wrap;
            }

            frames_layout := InfoRow {
                label: "Frames:";
                value: root.num_frames;
            }

            removed_layout := InfoRow {
                height: root.removed_frames_count > 0 ? MaterialStyleMetrics.size_40 : 0px;
                label: "Removed Frames:";
                value: root.removed_frames_count;
                text-color: MaterialPalette.error;
            }

            time_step_area := TouchArea {
                HorizontalLayout {
                    padding: MaterialStyleMetrics.padding_2;
                    TextField {
                        label: "Time Step (fs)";
                        horizontal-stretch: 1;
                        text <=> root.time_step;
                        height: MaterialStyleMetrics.size_40;
                        enabled: root.num_frames > 0;
                    }
                }
            }

            atoms_layout := InfoRow {
                label: "Total Atoms:";
                value: root.total_atoms;
            }

            HorizontalLayout {
                padding: MaterialStyleMetrics.padding_2;
                MaterialText {
                    text: "Atoms per element";
                }
            }

            for info in root.atom_counts: HorizontalLayout {
                padding: MaterialStyleMetrics.padding_2;
                MaterialText {
                    text: info.symbol + ":";
                    horizontal-stretch: 1;
                }

                MaterialText {
                    text: info.count;
                    horizontal-alignment: right;
                }
            }
        }
    }
}
