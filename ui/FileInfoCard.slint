import {
    MaterialStyleMetrics,
    MaterialTypography,
    MaterialPalette,
    FilledCard,
    MaterialText,
    TextField,
    InfoRow,
    ExpandableHeader,
} from "@material";
import { AtomCount } from "Types.slint";

// ============================================================================
// FileInfoCard Component
// ============================================================================
// This component displays information about the loaded structure or trajectory
// file, including atom counts, frame counts, and time steps.
// 
// C++ Binding Architecture:
// - Properties like `num_frames`, `total_atoms`, and `time_step` are populated
//   by the C++ backend (`AppBackend::load_file()`) when a file is successfully read.
// - The `AppController` pushes these values to the UI via the `AppWindow` 
//   properties.
// - The `time_step` property is a two-way binding: it receives a default from
//   C++ based on atom masses, but the user can edit it, and C++ reads it
//   before running dynamic analyses (e.g., VACF).
// ============================================================================
export component FileInfoCard inherits FilledCard {
    visible: root.file_loaded;
    in-out property <string> file_status_text;
    in property <bool> file_loaded;
    in property <int> num_frames;
    in property <int> total_atoms;
    in property <int> removed_frames_count;
    in property <[AtomCount]> atom_counts;
    in-out property <string> time_step;

    out property <bool> frames_hover: frames_layout.has-hover;
    out property <bool> atoms_hover: atoms_layout.has-hover;
    out property <bool> removed_frames_hover: removed_layout.has-hover;
    out property <bool> time_step_hover: time_step_area.has-hover;
    in-out property <bool> atoms_expanded: false;

    property <length> atoms_height: atoms_expanded ? root.atom_counts.length * 36px : 0px;
    property <length> frames_height: root.num_frames > 1 ? MaterialStyleMetrics.size_40 : 0px;
    property <length> removed_height: (root.num_frames > 1 && root.removed_frames_count > 0) ? MaterialStyleMetrics.size_40 : 0px;
    property <length> time_step_height: root.num_frames > 1 ? MaterialStyleMetrics.size_40 : 0px;

    VerticalLayout {
        padding: MaterialStyleMetrics.spacing_8;
        spacing: MaterialStyleMetrics.spacing_4;

        MaterialText {
            text: root.file_status_text;
            horizontal-stretch: 1;
            wrap: word-wrap;
        }

        atoms_layout := ExpandableHeader {
            text: "Total Atoms: " + root.total_atoms;
            expanded <=> root.atoms_expanded;
        }

        VerticalLayout {
            height: root.atoms_height;
            opacity: root.atoms_expanded ? 1.0 : 0.0;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            spacing: MaterialStyleMetrics.spacing_2;
            for info in root.atom_counts: InfoRow {
                label: info.symbol + ":";
                value: info.count;
            }
        }

        frames_layout := InfoRow {
            opacity: root.num_frames > 1 ? 1.0 : 0.0;
            height: root.frames_height;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            label: "Frames:";
            value: root.num_frames;
        }

        removed_layout := InfoRow {
            opacity: (root.num_frames > 1 && root.removed_frames_count > 0) ? 1.0 : 0.0;
            height: root.removed_height;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            label: "Removed Frames:";
            value: root.removed_frames_count;
            text-color: MaterialPalette.error;
        }

        time_step_area := TouchArea {
            opacity: root.num_frames > 1 ? 1.0 : 0.0;
            height: root.time_step_height;
            animate height {
                duration: 250ms;
                easing: ease-in-out;
            }
            animate opacity {
                duration: 250ms;
                easing: ease-in-out;
            }
            HorizontalLayout {
                padding: MaterialStyleMetrics.padding_2;
                TextField {
                    label: "Time Step (fs)";
                    horizontal-stretch: 1;
                    text <=> root.time_step;
                    height: root.time_step_height;
                    animate height {
                        duration: 250ms;
                        easing: ease-in-out;
                    }
                    enabled: root.num_frames > 1;
                }
            }
        }
    }
}
