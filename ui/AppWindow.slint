import {
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialTypography,
    MaterialText,
    MenuItem,
    Vertical,
    Horizontal,
    Icons,
    FilledButton,
    ScrollView,
} from "material/material.slint";
import { Palette } from "std-widgets.slint";

import {
    AtomCount,
    BondCutoff,
    CalculatorInfo,
    CalculatorGroup,
} from "Types.slint";

import { OperationsCard } from "run/OperationsCard.slint";
import { TrajectoryOptionsCard } from "options/TrajectoryOptionsCard.slint";
import { FileExportCard } from "options/FileExportCard.slint";
import { CliCommandCard } from "run/CliCommandCard.slint";
import { AnalysesSelectionCard } from "options/AnalysesSelectionCard.slint";
import { PresetManagerCard } from "options/PresetManagerCard.slint";
import { RDFOptionsCard } from "options/RDFOptionsCard.slint";
import { SQOptionsCard } from "options/SQOptionsCard.slint";
import { BondAngleOptionsCard } from "options/BondAngleOptionsCard.slint";
import { RingsOptionsCard } from "options/RingsOptionsCard.slint";
import { SmoothingOptionsCard } from "options/SmoothingOptionsCard.slint";
import { BondCutoffsCard } from "options/BondCutoffsCard.slint";
import { PreviewCard } from "preview/PreviewCard.slint";
import { AppToolTips } from "AppToolTips.slint";

export {
    AtomCount,
    BondCutoff,
    CalculatorInfo,
    CalculatorGroup,
}

// ============================================================================
// AppWindow Component
// ============================================================================
/// This is the main window component for the Correlation application.
/// 
/// C++ Binding Architecture:
/// - The `AppWindow` instance is managed by the `AppController` in C++.
/// - Root properties (like `file_loaded`, `progress`, etc.) are bound to 
///   the `AppController` and `AppBackend` states.
/// - Callbacks (like `run_analysis`, `browse_file`) are mapped to methods in
///   the `AppController` to handle user interactions.
/// - hovered_tooltip_text: A string that is dynamically updated based on the
///   hovered component.
// ============================================================================
component TabItem inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    height: 36px;
    background: transparent;

    property <bool> is_dark: Palette.color_scheme == ColorScheme.dark;

    states [
        hover when touch.has-hover: {
            background: root.is_dark ? #ffffff.with_alpha(5%) : #000000.with_alpha(5%);
        }
    ]

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Vertical {
        alignment: center;
        MaterialText {
            text: root.text;
            style: MaterialTypography.label_medium;
            font_weight: active ? MaterialTypography.semibold : MaterialTypography.medium;
            color: active ? MaterialPalette.primary : MaterialPalette.on_surface_variant;
            horizontal-alignment: center;
        }
    }

    // Bottom active indicator line
    Rectangle {
        y: parent.height - 2px;
        height: 2px;
        width: active ? 80% : 0%;
        background: MaterialPalette.primary;
        border_radius: 1px;

        animate width {
            duration: 150ms;
            easing: ease-in-out;
        }
    }
}

// ============================================================================
export component AppWindow inherits Window {
    // ============================================================================
    // Global Properties
    // ============================================================================
    
    /// Status of the file dialog timer
    in property <bool> timer_running: false;

    /// File status and metadata
    in property <bool> file_loaded: false;
    in property <int> num_frames: 0;
    in property <int> total_atoms: 0;
    in property <int> removed_frames_count: 0;
    in property <[AtomCount]> atom_counts: [];
    in-out property <string> file_status_text: "No file loaded.";
    in-out property <string> time_step: "1.0";

    /// Analysis execution state
    in property <bool> analysis_running: false;
    in property <bool> analysis_done: false;
    in property <float> progress: 0.0;
    in property <bool> text_opacity: false;
    in-out property <string> analysis_status_text: "Ready to run analysis.";

    /// Analysis configuration properties
    in-out property <string> in_file_text;
    in property <bool> hdf5_available: true;
    in property <bool> parquet_available: true;
    in-out property <bool> use_csv: true;
    in-out property <bool> use_hdf5: false;
    in-out property <bool> use_parquet: false;
    in-out property <string> min_frame: "0";
    in-out property <string> max_frame: "End";
    in-out property <string> r_max: "20.0";
    in-out property <string> r_bin_width: "0.02";
    in-out property <string> q_max: "20.0";
    in-out property <string> q_bin_width: "0.02";
    in-out property <string> r_int_max: "10.0";
    in-out property <string> angle_bin_width: "1.0";
    in-out property <string> dihedral_bin_width: "1.0";
    in-out property <string> max_ring_size: "12";
    in-out property <bool> smoothing: true;
    in-out property <string> smoothing_sigma: "0.01";
    in-out property <int> smoothing_kernel: 0;
    in-out property <[BondCutoff]> bond_cutoffs: [];

    // Validation error messages (empty string = valid)
    in-out property <string> r_max_error: "";
    in-out property <string> r_bin_error: "";
    in-out property <string> q_max_error: "";
    in-out property <string> q_bin_error: "";
    in-out property <string> r_int_max_error: "";
    in-out property <string> angle_bin_error: "";
    in-out property <string> dihedral_bin_error: "";
    in-out property <string> max_ring_error: "";
    in-out property <string> smoothing_sigma_error: "";
    in-out property <string> min_frame_error: "";
    in-out property <string> max_frame_error: "";
    in-out property <string> time_step_error: "";

    // Export settings properties and errors
    in-out property <int> export_size_preset: 0;
    in-out property <int> export_palette: 0;
    in-out property <string> export_font_scale: "1.0";
    in-out property <string> export_line_width: "3.0";
    in-out property <bool> export_show_legend: true;
    in-out property <bool> export_show_grid: true;
    in-out property <string> export_font_scale_error: "";
    in-out property <string> export_line_width_error: "";

    // Global: any validation error prevents running analysis
    in-out property <bool> has_validation_errors: false;
    in-out property <string> cli_command: "";

    // Presets properties
    in property <[MenuItem]> preset_items: [];
    in-out property <int> selected_preset: -1;

    /// Dynamic calculator groups from CalculatorFactory via C++
    in-out property <[CalculatorGroup]> calculator_groups: [];
    in property <int> total_calculator_count: 0;

    /// Active group flags for auto-hiding option cards
    in property <bool> has_radial_active: false;
    in property <bool> has_scattering_active: false;
    in property <bool> has_angular_active: false;
    in property <bool> has_rings_active: false;

    /// Analysis results and preview
    in property <image> preview_plot;
    in property <[MenuItem]> plot_items: [];
    in-out property <int> selected_plot_index: -1;
    in property <int> pinned_runs_count: 0;
    out property <bool> is_dark: Palette.color_scheme == ColorScheme.dark;

    // ============================================================================
    // Callbacks (Bound to AppController.cpp)
    // ============================================================================
    callback browse_file();
    callback run_analysis();
    callback write_files();
    callback select_plot(int);
    callback toggle_calculator(string, bool);
    callback check_file_dialog_status();
    callback save_plot();
    callback pin_run();
    callback clear_pinned_runs();
    callback validate_inputs();
    callback copy_cli_command();

    // Presets callbacks
    callback load_preset(int);
    callback save_preset(string);
    callback delete_preset(int);

    // ============================================================================
    // Core Layout Logic
    // ============================================================================
    
    changed r_max => {
        root.validate_inputs();
    }
    changed r_bin_width => {
        root.validate_inputs();
    }
    changed q_max => {
        root.validate_inputs();
    }
    changed q_bin_width => {
        root.validate_inputs();
    }
    changed r_int_max => {
        root.validate_inputs();
    }
    changed angle_bin_width => {
        root.validate_inputs();
    }
    changed dihedral_bin_width => {
        root.validate_inputs();
    }
    changed max_ring_size => {
        root.validate_inputs();
    }
    changed smoothing => {
        root.validate_inputs();
    }
    changed smoothing_sigma => {
        root.validate_inputs();
    }
    changed min_frame => {
        root.validate_inputs();
    }
    changed max_frame => {
        root.validate_inputs();
    }
    changed time_step => {
        root.validate_inputs();
    }

    changed export_size_preset => {
        root.select_plot(root.selected_plot_index);
    }
    changed export_palette => {
        root.select_plot(root.selected_plot_index);
    }
    changed export_font_scale => {
        root.validate_inputs();
        root.select_plot(root.selected_plot_index);
    }
    changed export_line_width => {
        root.validate_inputs();
        root.select_plot(root.selected_plot_index);
    }
    changed export_show_legend => {
        root.select_plot(root.selected_plot_index);
    }
    changed export_show_grid => {
        root.select_plot(root.selected_plot_index);
    }

    Timer {
        interval: 100ms;
        running: root.timer_running;
        triggered() => {
            root.check_file_dialog_status();
        }
    }

    /// hovered_tooltip_text: Dynamically update based on the currently
    ///   hovered component.
    property <string> sidebar_tooltip: operations_card.hovered_tooltip_text;

    property <string> options_hovered_tooltip: "";
    property <string> preview_hovered_tooltip: "";

    property <string> hovered_tooltip_text: 
        sidebar_tooltip != "" ? sidebar_tooltip : options_hovered_tooltip != "" ? options_hovered_tooltip : preview_hovered_tooltip;

    title: "Correlation";
    background: MaterialPalette.background;
    default-font-size: MaterialTypography.body_small.font_size;
    default-font-weight: MaterialTypography.body_small.font_weight;
    default-font-family: "Inter";
    min-width: 950px;
    min-height: 650px;
    preferred-width: 1080px;
    preferred-height: 720px;

    // ============================================================================
    // Main UI structure
    // ============================================================================
    window_area := TouchArea {
        Horizontal {
            // 1. Left column: Operations & CLI command
            Vertical {
                padding: 0;
                width: 260px;
                horizontal-stretch: 0;
                spacing: MaterialStyleMetrics.spacing_8;

                operations_card := OperationsCard {
                    load_enabled: !root.timer_running;
                    browse_file => {
                        root.browse_file();
                    }
                    file_status_text <=> root.file_status_text;
                    file_loaded: root.file_loaded;
                    num_frames: root.num_frames;
                    total_atoms: root.total_atoms;
                    removed_frames_count: root.removed_frames_count;
                    atom_counts: root.atom_counts;

                    analysis_running: root.analysis_running;
                    analysis_done: root.analysis_done;
                    progress: root.progress;
                    analysis_status_text: root.analysis_status_text;
                    has_validation_errors: root.has_validation_errors;
                    run_analysis => {
                        root.run_analysis();
                    }
                    write_files => {
                        root.write_files();
                    }
                }

                //CliCommandCard {
                //    cli_command: root.cli_command;
                //    copy_command => {
                //        root.copy_cli_command();
                //    }
                //}
            }

            // 2. Middle column: Options Tabbed Card (Setup, Trajectory, Parameters, Export)
            Rectangle {
                width: 340px;
                horizontal-stretch: 0;

                options_container := Vertical {
                    width: 100%;
                    height: 100%;
                    padding: 0;
                    opacity: root.file_loaded ? 1.0 : 0.5;
                    animate opacity { duration: 150ms; }

                    // TAB NAVIGATION BAR (4 tabs)
                    property <int> active_tab: 0;
                    Horizontal {
                        height: 40px;
                        spacing: 4px;
                        padding-bottom: 4px;

                        TabItem {
                            text: "Parameters";
                            active: options_container.active_tab == 0;
                            clicked => { options_container.active_tab = 0; }
                        }

                        TabItem {
                            text: "Trajectory";
                            active: options_container.active_tab == 1;
                            clicked => { options_container.active_tab = 1; }
                        }

                        TabItem {
                            text: "Export";
                            active: options_container.active_tab == 2;
                            clicked => { options_container.active_tab = 2; }
                        }

                        TabItem {
                            text: "Setup";
                            active: options_container.active_tab == 3;
                            clicked => { options_container.active_tab = 3; }
                        }
                    }

                    property <string> local_tooltip: 
                        (options_container.active_tab == 3 && preset_card.hovered_tooltip_text != "") ? preset_card.hovered_tooltip_text :
                        (options_container.active_tab == 3 && analyses_card.hovered_calculator_description != "") ? analyses_card.hovered_calculator_description :
                        (options_container.active_tab == 1 && trajectory_card.hovered_tooltip_text != "") ? trajectory_card.hovered_tooltip_text :
                        (options_container.active_tab == 0 && rdf_card.hovered_tooltip_text != "") ? rdf_card.hovered_tooltip_text :
                        (options_container.active_tab == 0 && sq_card.hovered_tooltip_text != "") ? sq_card.hovered_tooltip_text :
                        (options_container.active_tab == 0 && smoothing_card.hovered_tooltip_text != "") ? smoothing_card.hovered_tooltip_text :
                        (options_container.active_tab == 0 && angle_card.hovered_tooltip_text != "") ? angle_card.hovered_tooltip_text :
                        (options_container.active_tab == 0 && rings_card.hovered_tooltip_text != "") ? rings_card.hovered_tooltip_text :
                        (options_container.active_tab == 2 && file_export_card.hovered_tooltip_text != "") ? file_export_card.hovered_tooltip_text : "";

                    changed local_tooltip => {
                        root.options_hovered_tooltip = self.local_tooltip;
                    }

                    ScrollView {
                        viewport-height: options_layout.preferred-height;
                        options_layout := Vertical {
                            padding: 0;
                            spacing: MaterialStyleMetrics.spacing_4;

                            // Trajectory Tab (Time Step & Frame Range)
                            trajectory_card := TrajectoryOptionsCard {
                                file_loaded: root.file_loaded;
                                num_frames: root.num_frames;
                                time_step <=> root.time_step;
                                time_step_error: root.time_step_error;
                                min_frame <=> root.min_frame;
                                max_frame <=> root.max_frame;
                                min_frame_error: root.min_frame_error;
                                max_frame_error: root.max_frame_error;
                                visible: options_container.active_tab == 1;
                                height: options_container.active_tab == 1 ? self.preferred-height : 0px;
                            }

                            // Parameters Tab (Bond Cutoffs, RDF, SQ, Angular, Rings, Smoothing Options)
                            bond_cutoffs_card := BondCutoffsCard {
                                file_loaded: root.file_loaded;
                                bond_cutoffs <=> root.bond_cutoffs;
                                atom_counts: root.atom_counts;
                                visible: options_container.active_tab == 0;
                                height: options_container.active_tab == 0 ? self.preferred-height : 0px;
                            }

                            rdf_card := RDFOptionsCard {
                                file_loaded: root.file_loaded;
                                r_max <=> root.r_max;
                                r_bin_width <=> root.r_bin_width;
                                r_max_error: root.r_max_error;
                                r_bin_error: root.r_bin_error;
                                visible: options_container.active_tab == 0 && root.has_radial_active;
                                height: (options_container.active_tab == 0 && root.has_radial_active) ? self.preferred-height : 0px;
                            }

                            angle_card := BondAngleOptionsCard {
                                file_loaded: root.file_loaded;
                                angle_bin_width <=> root.angle_bin_width;
                                dihedral_bin_width <=> root.dihedral_bin_width;
                                angle_bin_error: root.angle_bin_error;
                                dihedral_bin_error: root.dihedral_bin_error;
                                visible: options_container.active_tab == 0 && root.has_angular_active;
                                height: (options_container.active_tab == 0 && root.has_angular_active) ? self.preferred-height : 0px;
                            }

                            sq_card := SQOptionsCard {
                                file_loaded: root.file_loaded;
                                q_max <=> root.q_max;
                                q_bin_width <=> root.q_bin_width;
                                r_int_max <=> root.r_int_max;
                                q_max_error: root.q_max_error;
                                q_bin_error: root.q_bin_error;
                                r_int_max_error: root.r_int_max_error;
                                visible: options_container.active_tab == 0 && root.has_scattering_active;
                                height: (options_container.active_tab == 0 && root.has_scattering_active) ? self.preferred-height : 0px;
                            }

                            smoothing_card := SmoothingOptionsCard {
                                file_loaded: root.file_loaded;
                                smoothing_enabled <=> root.smoothing;
                                smoothing_sigma <=> root.smoothing_sigma;
                                smoothing_kernel <=> root.smoothing_kernel;
                                smoothing_sigma_error: root.smoothing_sigma_error;
                                visible: options_container.active_tab == 0;
                                height: options_container.active_tab == 0 ? self.preferred-height : 0px;
                            }

                            rings_card := RingsOptionsCard {
                                file_loaded: root.file_loaded;
                                max_ring_size <=> root.max_ring_size;
                                max_ring_error: root.max_ring_error;
                                visible: options_container.active_tab == 0 && root.has_rings_active;
                                height: (options_container.active_tab == 0 && root.has_rings_active) ? self.preferred-height : 0px;
                            }

                            // Export Tab (File Export Format Checkboxes)
                            file_export_card := FileExportCard {
                                file_loaded: root.file_loaded;
                                hdf5_available: root.hdf5_available;
                                parquet_available: root.parquet_available;
                                use_csv <=> root.use_csv;
                                use_hdf5 <=> root.use_hdf5;
                                use_parquet <=> root.use_parquet;
                                visible: options_container.active_tab == 2;
                                height: options_container.active_tab == 2 ? self.preferred-height : 0px;
                            }

                            // Setup Tab (Presets, Calculator Selections)
                            preset_card := PresetManagerCard {
                                enabled: root.file_loaded;
                                preset_items: root.preset_items;
                                selected_preset <=> root.selected_preset;
                                load_preset(idx) => {
                                    root.load_preset(idx);
                                }
                                save_preset(name) => {
                                    root.save_preset(name);
                                }
                                delete_preset(idx) => {
                                    root.delete_preset(idx);
                                }
                                visible: options_container.active_tab == 3;
                                height: options_container.active_tab == 3 ? self.preferred-height : 0px;
                            }

                            analyses_card := AnalysesSelectionCard {
                                file_loaded: root.file_loaded;
                                calculator_groups: root.calculator_groups;
                                total_calculator_count: root.total_calculator_count;
                                toggle_calculator(id, enabled) => {
                                    root.toggle_calculator(id, enabled);
                                }
                                visible: options_container.active_tab == 3;
                                height: options_container.active_tab == 3 ? self.preferred-height : 0px;
                            }

                            // Tab placeholder if no options active
                            if (options_container.active_tab == 0 && !root.has_radial_active && !root.has_scattering_active && !root.has_angular_active && !root.has_rings_active): Vertical {
                                alignment: center;
                                padding: 16px;
                                spacing: 8px;
                                MaterialText {
                                    text: "No parameters available for active calculators.";
                                    style: MaterialTypography.body_medium;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Block interactions if not file_loaded
                if !root.file_loaded: TouchArea {
                    width: 100%;
                    height: 100%;
                }
            }

            // 3. Right column: Visual Preview Card (stretches to fill remaining space)
            Rectangle {
                horizontal-stretch: 1;

                Vertical {
                    width: 100%;
                    height: 100%;
                    padding: 0;
                    opacity: root.analysis_done ? 1.0 : 0.5;
                    animate opacity { duration: 150ms; }

                    property <string> local_tooltip: preview_card.hovered_tooltip_text;
                    changed local_tooltip => {
                        root.preview_hovered_tooltip = self.local_tooltip;
                    }

                    preview_card := PreviewCard {
                        vertical-stretch: 1;
                        horizontal-stretch: 1;
                        preview_plot <=> root.preview_plot;
                        plot_items <=> root.plot_items;
                        selected_plot_index <=> root.selected_plot_index;
                        pinned_runs_count: root.pinned_runs_count;

                        export_size_preset <=> root.export_size_preset;
                        export_palette <=> root.export_palette;
                        export_font_scale <=> root.export_font_scale;
                        export_line_width <=> root.export_line_width;
                        export_show_legend <=> root.export_show_legend;
                        export_show_grid <=> root.export_show_grid;
                        export_font_scale_error: root.export_font_scale_error;
                        export_line_width_error: root.export_line_width_error;

                        plot_selected(idx) => {
                            root.select_plot(idx);
                        }
                        save_plot => {
                            root.save_plot();
                        }
                        pin_run => {
                            root.pin_run();
                        }
                        clear_pinned_runs => {
                            root.clear_pinned_runs();
                        }
                    }
                }

                // Block interactions if not analysis_done
                if !root.analysis_done: TouchArea {
                    width: 100%;
                    height: 100%;
                }
            }
        }
    }

    AppToolTips {
        x: 0;
        y: 0;
        mouse_x: window_area.mouse-x;
        mouse_y: window_area.mouse-y;
        hovered_tooltip_text: root.hovered_tooltip_text;
    }
}
