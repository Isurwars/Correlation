import {
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialTypography,
    MaterialText,
    MenuItem,
} from "@material";

import {
    AtomCount,
    BondCutoff,
    CalculatorInfo,
    CalculatorGroup,
} from "Types.slint";
import { InputFileCard } from "InputFileCard.slint";
import { FileInfoCard } from "FileInfoCard.slint"; 
import { OptionsCard } from "OptionsCard.slint";
import { RunAnalysisCard } from "RunAnalysisCard.slint";
import { PreviewCard } from "PreviewCard.slint";
import { AppToolTips } from "AppToolTips.slint";

export { AtomCount, BondCutoff, CalculatorInfo, CalculatorGroup }

// ============================================================================
// AppWindow Component
// ============================================================================
/// This is the root component of the GUI. Its properties (`in-out property <...>`) 
/// and callbacks (`callback ...`) form the main interface with the C++ backend.
///
/// C++ Binding Architecture:
/// - Callbacks (e.g., `run_analysis()`, `browse_file()`) are implemented in C++
///   (via `AppController.cpp`) using `ui->on_run_analysis([...])` to handle events.
/// - Properties (e.g., `file_status_text`, `r_max`, `use_csv`) are read and written
///   from C++ using getters (`ui->get_r_max()`) and setters (`ui->set_progress(...)`).
/// - The C++ application holds an instance of `AppWindow` and updates its state
///   based on backend computations, while the UI triggers backend actions.
// ============================================================================
export component AppWindow inherits Window {
    /// Callback that the UI invokes on the C++ side
    callback run_analysis();
    callback write_files();
    callback browse_file();
    callback check_file_dialog_status();

    /// Properties that C++ updates to change the UI
    in-out property <string> file_status_text: "Please load a structure file.";
    in-out property <string> analysis_status_text: "";
    in-out property <float> progress: 0.0;
    in-out property <bool> analysis_running: false;
    in-out property <bool> analysis_done: false;
    in-out property <bool> timer_running: false;
    in-out property <bool> text_opacity: true;
    in-out property <bool> file_loaded: false;
    in-out property <bool> is_dark: false;

    /// Data for the UI
    in-out property <int> num_frames: 0;
    in-out property <int> total_atoms: 0;
    in-out property <int> removed_frames_count: 0;
    in-out property <[AtomCount]> atom_counts: [];
    in-out property <[BondCutoff]> bond_cutoffs: [];
    in-out property <string> time_step: "1.0";

    /// User-configurable options
    in-out property <string> in_file_text;
    in-out property <bool> smoothing: true;
    in-out property <bool> use_hdf5: true;
    in-out property <bool> use_csv: false;
    in-out property <bool> use_parquet: false;
    in-out property <string> r_max;
    in-out property <string> r_bin_width;
    in-out property <string> q_max;
    in-out property <string> q_bin_width;
    in-out property <string> r_int_max;
    in-out property <string> angle_bin_width;
    in-out property <string> dihedral_bin_width;
    in-out property <string> max_ring_size;
    in-out property <string> smoothing_sigma;
    in-out property <int> smoothing_kernel: -1;
    in-out property <string> min_frame: "1";
    in-out property <string> max_frame: "End";

    /// Analysis calculator groups (dynamically populated from C++)
    in-out property <[CalculatorGroup]> calculator_groups: [];
    in-out property <int> total_calculator_count: 0;
    callback toggle_calculator(string, bool);

    /// Plot preview (populated after analysis completes)
    in-out property <image> preview_plot;
    in-out property <[MenuItem]> plot_items: [];
    in-out property <int> selected_plot_index: -1;
    callback select_plot(int);
    property <string> hovered_tooltip_text:
        input_card.hovered_tooltip_text != "" ? input_card.hovered_tooltip_text : file_info_card.hovered_tooltip_text != "" ? file_info_card.hovered_tooltip_text : analysis_card.hovered_tooltip_text != "" ? analysis_card.hovered_tooltip_text : options_card.hovered_tooltip_text != "" ? options_card.hovered_tooltip_text : preview_card.hovered_tooltip_text != "" ? preview_card.hovered_tooltip_text : "";
    property <bool> show_advanced_options: false;
    property <length> window_width: 392px + (root.show_advanced_options ? 220px : 0px) + (root.analysis_done ? 582px : 0px);
    property <length> window_height: max(
        max(110px + file_info_card.preferred-height, 100px + analysis_card.preferred-height),
        root.show_advanced_options ? 60px + options_card.preferred-height : 0px,
        root.analysis_done ? 20px + preview_card.preferred-height : 0px);
    width: root.window_width;
    height: root.window_height;
    title: "Correlation";
    animate width {
        duration: 100ms;
        easing: ease-in-out;
    }
    animate height {
        duration: 100ms;
        easing: ease-in-out;
    }
    background: MaterialPalette.background;
    default-font-size: MaterialTypography.body_small.font_size;
    default-font-weight: MaterialTypography.body_small.font_weight;
    default-font-family: "sans-serif";
    property <image> logo-icon: @image-url("../Images/Logo.png");
    icon: logo-icon;
    timer := Timer {
        interval: 200ms;
        running: timer_running;
        triggered() => {
            check_file_dialog_status();
        }
    }

    window_area := TouchArea {
        width: 100%;
        height: 100%;
        Rectangle {
            // 1. Sidebar: Input & File Info
            VerticalLayout {
                x: 0px;
                y: 0px;
                width: 190px;
                padding-left: MaterialStyleMetrics.spacing_8;
                padding-top: MaterialStyleMetrics.spacing_8;
                padding-bottom: MaterialStyleMetrics.spacing_8;
                padding-right: 0px;
                spacing: MaterialStyleMetrics.spacing_4;
                alignment: end;
                input_card := InputFileCard {
                    enabled: !root.timer_running;
                    browse_file => {
                        root.browse_file();
                    }
                }

                file_info_card := FileInfoCard {
                    height: root.height - input_card.preferred-height - 20px;
                    file_status_text <=> root.file_status_text;
                    file_loaded: root.file_loaded;
                    num_frames: root.num_frames;
                    total_atoms: root.total_atoms;
                    removed_frames_count: root.removed_frames_count;
                    atom_counts: root.atom_counts;
                    time_step <=> root.time_step;
                }
            }

            // 2. Center: Output & Run
        VerticalLayout {
                x: 194px;
                y: 0px;
                width: 190px;
                padding-left: 0px;
                padding-top: MaterialStyleMetrics.spacing_8;
                padding-bottom: MaterialStyleMetrics.spacing_8;
                padding-right: 0px;
                spacing: MaterialStyleMetrics.spacing_4;
                analysis_card := RunAnalysisCard {
                    file_loaded: root.file_loaded;
                    num_frames: root.num_frames;
                    analysis_running: root.analysis_running;
                    analysis_done: root.analysis_done;
                    progress: root.progress;
                    analysis_status_text <=> root.analysis_status_text;
                    use_csv <=> root.use_csv;
                    use_hdf5 <=> root.use_hdf5;
                    use_parquet <=> root.use_parquet;
                    min_frame <=> root.min_frame;
                    max_frame <=> root.max_frame;
                    advanced_options_visible <=> root.show_advanced_options;
                    run_analysis => {
                        root.run_analysis();
                    }
                    write_files => {
                        root.write_files();
                    }
                    options_toggled(visible) => {
                        if (!visible) {
                            options_card.analyses_expanded = false;
                            options_card.rdf_expanded = false;
                            options_card.sq_expanded = false;
                            options_card.angle_expanded = false;
                            options_card.smoothing_expanded = false;
                            options_card.bond_cutoffs_expanded = false;
                        }
                    }
                }
            }

            // 3. Right: Analysis Options
        VerticalLayout {
                x: 388px;
                y: 0px;
                width: root.show_advanced_options ? 220px : 0.1px;
                visible: root.show_advanced_options || self.width > 1px;
                padding-left: 0px;
                padding-top: MaterialStyleMetrics.spacing_8;
                padding-bottom: MaterialStyleMetrics.spacing_8;
                padding-right: MaterialStyleMetrics.spacing_4;
                spacing: MaterialStyleMetrics.spacing_4;
                options_card := OptionsCard {
                    file_loaded <=> root.file_loaded;
                    calculator_groups <=> root.calculator_groups;
                    total_calculator_count <=> root.total_calculator_count;
                    toggle_calculator(id, enabled) => {
                        root.toggle_calculator(id, enabled);
                    }
                    r_max <=> root.r_max;
                    r_bin_width <=> root.r_bin_width;
                    q_max <=> root.q_max;
                    q_bin_width <=> root.q_bin_width;
                    r_int_max <=> root.r_int_max;
                    angle_bin_width <=> root.angle_bin_width;
                    dihedral_bin_width <=> root.dihedral_bin_width;
                    max_ring_size <=> root.max_ring_size;
                    smoothing <=> root.smoothing;
                    smoothing_sigma <=> root.smoothing_sigma;
                    smoothing_kernel <=> root.smoothing_kernel;
                    bond_cutoffs <=> root.bond_cutoffs;
                }
            }
 
            // 4. Far-right: Distribution Function Preview
        VerticalLayout {
                x: 388px + (root.show_advanced_options ? 224px : 4px);
                y: 0px;
                width: root.analysis_done ? 576px : 0.1px;
                visible: root.analysis_done || self.width > 1px;
                padding-left: 0px;
                padding-top: MaterialStyleMetrics.spacing_8;
                padding-bottom: MaterialStyleMetrics.spacing_8;
                padding-right: MaterialStyleMetrics.spacing_8;
                spacing: MaterialStyleMetrics.spacing_4;
                opacity: root.analysis_done ? 1.0 : (self.width > 1px ? 0.0 : 1.0);
                animate width {
                    duration: 200ms;
                    easing: ease-in-out;
                }
                animate opacity {
                    duration: 200ms;
                    easing: ease-in-out;
                }
                preview_card := PreviewCard {
                    analysis_done: root.analysis_done;
                    preview_plot <=> root.preview_plot;
                    plot_items <=> root.plot_items;
                    selected_plot_index <=> root.selected_plot_index;
                    plot_selected(idx) => {
                        root.select_plot(idx);
                    }
                }
            }
        }

        AppToolTips {
            x: 0;
            y: 0;
            width: 100%;
            height: 100%;
            mouse_x: window_area.mouse-x;
            mouse_y: window_area.mouse-y;
            hovered_tooltip_text: root.hovered_tooltip_text;
        }
    }
}
