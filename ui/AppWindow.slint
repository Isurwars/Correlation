import {
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialTypography,
    MaterialText,
    MenuItem,
    Vertical,
    Horizontal,
    Icons,
    FilledButton,
    ScrollView,
} from "material/material.slint";
import { Palette } from "std-widgets.slint";

import {
    AtomCount,
    BondCutoff,
    CalculatorInfo,
    CalculatorGroup,
    AnalysisOptions,
    AppErrors,
    ExportConfig,
} from "Types.slint";

import { OperationsCard } from "run/OperationsCard.slint";
import { TrajectoryOptionsCard } from "options/TrajectoryOptionsCard.slint";
import { CliCommandCard } from "run/CliCommandCard.slint";
import { AnalysesSelectionCard } from "options/AnalysesSelectionCard.slint";
import { PresetManagerCard } from "options/PresetManagerCard.slint";
import { RDFOptionsCard } from "options/RDFOptionsCard.slint";
import { SQOptionsCard } from "options/SQOptionsCard.slint";
import { BondAngleOptionsCard } from "options/BondAngleOptionsCard.slint";
import { RingsOptionsCard } from "options/RingsOptionsCard.slint";
import { SmoothingOptionsCard } from "options/SmoothingOptionsCard.slint";
import { BondCutoffsCard } from "options/BondCutoffsCard.slint";
import { MaterialTypeCard } from "options/MaterialTypeCard.slint";
import { PreviewCard } from "preview/PreviewCard.slint";
import { AppToolTips } from "AppToolTips.slint";

export {
    AtomCount,
    BondCutoff,
    CalculatorInfo,
    CalculatorGroup,
    AnalysisOptions,
    AppErrors,
    ExportConfig,
}

// ============================================================================
// AppWindow Component
// ============================================================================
/// This is the main window component for the Correlation application.
/// 
/// C++ Binding Architecture:
/// - The `AppWindow` instance is managed by the `AppController` in C++.
/// - Root properties (like `file_loaded`, `progress`, etc.) are bound to 
///   the `AppController` and `AppBackend` states.
/// - Callbacks (like `run_analysis`, `browse_file`) are mapped to methods in
///   the `AppController` to handle user interactions.
/// - hovered_tooltip_text: A string that is dynamically updated based on the
///   hovered component.
// ============================================================================
component TabItem inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    height: 36px;
    background: transparent;

    property <bool> is_dark: Palette.color_scheme == ColorScheme.dark;

    states [
        hover when touch.has-hover: {
            background: root.is_dark ? #ffffff.with_alpha(5%) : #000000.with_alpha(5%);
        }
    ]

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Vertical {
        alignment: center;
        MaterialText {
            text: root.text;
            style: MaterialTypography.label_medium;
            font_weight: active ? MaterialTypography.semibold : MaterialTypography.medium;
            color: active ? MaterialPalette.primary : MaterialPalette.on_surface_variant;
            horizontal-alignment: center;
        }
    }

    // Bottom active indicator line
    Rectangle {
        y: parent.height - 2px;
        height: 2px;
        width: active ? 80% : 0%;
        background: MaterialPalette.primary;
        border_radius: 1px;

        animate width {
            duration: 150ms;
            easing: ease-in-out;
        }
    }
}

// ============================================================================
export component AppWindow inherits Window {
    // ============================================================================
    // Global Properties
    // ============================================================================
    
    /// Status of the file dialog timer
    in property <bool> timer_running: false;

    /// File status and metadata
    in property <bool> file_loaded: false;
    in property <int> num_frames: 0;
    in property <int> total_atoms: 0;
    in property <int> removed_frames_count: 0;
    in property <[AtomCount]> atom_counts: [];
    in-out property <string> file_status_text: "No file loaded.";

    /// Analysis execution state
    in property <bool> analysis_running: false;
    in property <bool> analysis_done: false;
    in property <float> progress: 0.0;
    in property <bool> text_opacity: false;
    in-out property <string> analysis_status_text: "Ready to run analysis.";

    /// Analysis configuration properties
    in-out property <string> in_file_text;
    in property <bool> hdf5_available: true;
    in property <bool> parquet_available: true;
    in-out property <AnalysisOptions> analysis_options: {
        r_max: "20.0",
        r_bin_width: "0.02",
        q_max: "20.0",
        q_bin_width: "0.02",
        r_int_max: "10.0",
        angle_bin_width: "1.0",
        dihedral_bin_width: "1.0",
        max_ring_size: "12",
        smoothing_sigma: "0.01",
        smoothing_kernel: 0,
        smoothing_enabled: true,
        min_frame: "0",
        max_frame: "End",
        time_step: "1.0",
        material_type: 0
    };
    in-out property <AppErrors> app_errors;
    in-out property <[BondCutoff]> bond_cutoffs: [];
    in-out property <ExportConfig> export_config: {
        size_preset: 0,
        palette: 0,
        font_scale: "1.0",
        line_width: "3.0",
        show_legend: true,
        show_grid: true,
        show_markers: false,
        fill_area: false
    };

    property <string> min_frame <=> analysis_options.min_frame;
    property <string> max_frame <=> analysis_options.max_frame;
    property <string> r_max <=> analysis_options.r_max;
    property <string> r_bin_width <=> analysis_options.r_bin_width;
    property <string> q_max <=> analysis_options.q_max;
    property <string> q_bin_width <=> analysis_options.q_bin_width;
    property <string> r_int_max <=> analysis_options.r_int_max;
    property <string> angle_bin_width <=> analysis_options.angle_bin_width;
    property <string> dihedral_bin_width <=> analysis_options.dihedral_bin_width;
    property <string> max_ring_size <=> analysis_options.max_ring_size;
    property <bool> smoothing <=> analysis_options.smoothing_enabled;
    property <string> smoothing_sigma <=> analysis_options.smoothing_sigma;
    property <int> smoothing_kernel <=> analysis_options.smoothing_kernel;
    property <string> time_step <=> analysis_options.time_step;
    property <int> material_type <=> analysis_options.material_type;

    property <string> r_max_error <=> app_errors.r_max_error;
    property <string> r_bin_error <=> app_errors.r_bin_error;
    property <string> q_max_error <=> app_errors.q_max_error;
    property <string> q_bin_error <=> app_errors.q_bin_error;
    property <string> r_int_max_error <=> app_errors.r_int_max_error;
    property <string> angle_bin_error <=> app_errors.angle_bin_error;
    property <string> dihedral_bin_error <=> app_errors.dihedral_bin_error;
    property <string> max_ring_error <=> app_errors.max_ring_error;
    property <string> smoothing_sigma_error <=> app_errors.smoothing_sigma_error;
    property <string> min_frame_error <=> app_errors.min_frame_error;
    property <string> max_frame_error <=> app_errors.max_frame_error;
    property <string> time_step_error <=> app_errors.time_step_error;

    property <int> export_size_preset <=> export_config.size_preset;
    property <int> export_palette <=> export_config.palette;
    property <string> export_font_scale <=> export_config.font_scale;
    property <string> export_line_width <=> export_config.line_width;
    property <bool> export_show_legend <=> export_config.show_legend;
    property <bool> export_show_grid <=> export_config.show_grid;
    property <bool> export_show_markers <=> export_config.show_markers;
    property <bool> export_fill_area <=> export_config.fill_area;
    property <string> export_font_scale_error <=> app_errors.export_font_scale_error;
    property <string> export_line_width_error <=> app_errors.export_line_width_error;

    // Global: any validation error prevents running analysis
    in-out property <bool> has_validation_errors: false;
    in-out property <string> cli_command: "";

    // Presets properties
    in property <[MenuItem]> preset_items: [];
    in-out property <int> selected_preset: -1;

    /// Dynamic calculator groups from CalculatorFactory via C++
    in-out property <[CalculatorGroup]> calculator_groups: [];
    in property <int> total_calculator_count: 0;

    /// Active group flags for auto-hiding option cards
    in property <bool> has_radial_active: false;
    in property <bool> has_scattering_active: false;
    in property <bool> has_angular_active: false;
    in property <bool> has_rings_active: false;

    /// Analysis results and preview
    in property <image> preview_plot;
    in property <[MenuItem]> plot_items: [];
    in-out property <int> selected_plot_index: -1;
    in property <int> pinned_runs_count: 0;
    out property <bool> is_dark: Palette.color_scheme == ColorScheme.dark;

    // ============================================================================
    // Callbacks (Bound to AppController.cpp)
    // ============================================================================
    callback browse_file();
    callback run_analysis();
    callback cancel_analysis();
    callback write_files();
    callback select_plot(int);
    callback toggle_calculator(string, bool);
    callback save_plot();
    callback pin_run();
    callback clear_pinned_runs();
    callback validate_inputs();
    callback copy_cli_command();
    callback mouse_move(length, length, bool, length, length);
    callback plot_resized(length, length);

    // Presets callbacks
    callback load_preset(int);
    callback save_preset(string);
    callback delete_preset(int);
    callback material_type_changed(int);

    // ============================================================================
    // Core Layout Logic
    // ============================================================================
    

    changed r_max => {
        root.validate_inputs();
    }
    changed r_bin_width => {
        root.validate_inputs();
    }
    changed q_max => {
        root.validate_inputs();
    }
    changed q_bin_width => {
        root.validate_inputs();
    }
    changed r_int_max => {
        root.validate_inputs();
    }
    changed angle_bin_width => {
        root.validate_inputs();
    }
    changed dihedral_bin_width => {
        root.validate_inputs();
    }
    changed max_ring_size => {
        root.validate_inputs();
    }
    changed smoothing => {
        root.validate_inputs();
    }
    changed smoothing_sigma => {
        root.validate_inputs();
    }
    changed min_frame => {
        root.validate_inputs();
    }
    changed max_frame => {
        root.validate_inputs();
    }
    changed time_step => {
        root.validate_inputs();
    }
    changed material_type => {
        root.material_type_changed(root.material_type);
    }

    changed export_size_preset => {
        root.select_plot(root.selected_plot_index);
    }
    changed export_palette => {
        root.select_plot(root.selected_plot_index);
    }
    changed export_font_scale => {
        root.validate_inputs();
        root.select_plot(root.selected_plot_index);
    }
    changed export_line_width => {
        root.validate_inputs();
        root.select_plot(root.selected_plot_index);
    }
    changed export_show_legend => {
        root.select_plot(root.selected_plot_index);
    }
    changed export_show_grid => {
        root.select_plot(root.selected_plot_index);
    }
    changed export_show_markers => {
        root.select_plot(root.selected_plot_index);
    }
    changed export_fill_area => {
        root.select_plot(root.selected_plot_index);
    }
    changed is_dark => {
        root.select_plot(root.selected_plot_index);
    }



    /// hovered_tooltip_text: Dynamically update based on the currently
    ///   hovered component.
    property <string> sidebar_tooltip: 
        operations_card.hovered_tooltip_text != "" ? operations_card.hovered_tooltip_text :
        (trajectory_card.hovered_tooltip_text != "" ? trajectory_card.hovered_tooltip_text : "");

    property <string> options_hovered_tooltip: options_container.local_tooltip;
    property <string> preview_hovered_tooltip: preview_card.hovered_tooltip_text;

    property <string> hovered_tooltip_text: 
        sidebar_tooltip != "" ? sidebar_tooltip : options_hovered_tooltip != "" ? options_hovered_tooltip : preview_hovered_tooltip;

    property <length> hovered_x:
        operations_card.hovered_tooltip_text != "" ? operations_card.hovered_x :
        trajectory_card.hovered_tooltip_text != "" ? trajectory_card.hovered_x :
        options_hovered_tooltip != "" ? options_container.local_hovered_x :
        preview_hovered_tooltip != "" ? preview_card.hovered_x : 0px;

    property <length> hovered_y:
        operations_card.hovered_tooltip_text != "" ? operations_card.hovered_y :
        trajectory_card.hovered_tooltip_text != "" ? trajectory_card.hovered_y :
        options_hovered_tooltip != "" ? options_container.local_hovered_y :
        preview_hovered_tooltip != "" ? preview_card.hovered_y : 0px;

    property <length> hovered_width:
        operations_card.hovered_tooltip_text != "" ? operations_card.hovered_width :
        trajectory_card.hovered_tooltip_text != "" ? trajectory_card.hovered_width :
        options_hovered_tooltip != "" ? options_container.local_hovered_width :
        preview_hovered_tooltip != "" ? preview_card.hovered_width : 0px;

    property <length> hovered_height:
        operations_card.hovered_tooltip_text != "" ? operations_card.hovered_height :
        trajectory_card.hovered_tooltip_text != "" ? trajectory_card.hovered_height :
        options_hovered_tooltip != "" ? options_container.local_hovered_height :
        preview_hovered_tooltip != "" ? preview_card.hovered_height : 0px;

    title: "Correlation";
    background: MaterialPalette.background;
    default-font-size: MaterialTypography.body_small.font_size;
    default-font-weight: MaterialTypography.body_small.font_weight;
    default-font-family: "Outfit";
    min-width: 1050px;
    min-height: 725px;
    preferred-width: 1180px;
    preferred-height: 795px;

    // ============================================================================
    // Main UI structure
    // ============================================================================
        Horizontal {
            // 1. Left column: Operations & CLI command
            Vertical {
            padding: 0;
            width: 260px;
            horizontal-stretch: 0;
            spacing: MaterialStyleMetrics.spacing_8;

            operations_card := OperationsCard {
                load_enabled: !root.timer_running;
                browse_file => {
                    root.browse_file();
                }
                file_status_text <=> root.file_status_text;
                file_loaded: root.file_loaded;
                num_frames: root.num_frames;
                total_atoms: root.total_atoms;
                removed_frames_count: root.removed_frames_count;
                atom_counts: root.atom_counts;

                analysis_running: root.analysis_running;
                analysis_done: root.analysis_done;
                progress: root.progress;
                analysis_status_text: root.analysis_status_text;
                has_validation_errors: root.has_validation_errors;
                run_analysis => {
                    root.run_analysis();
                }
                cancel_analysis => {
                    root.cancel_analysis();
                }
                write_files => {
                    root.write_files();
                }
            }

            trajectory_card := TrajectoryOptionsCard {
                file_loaded: root.file_loaded;
                num_frames: root.num_frames;
                time_step <=> root.time_step;
                time_step_error: root.time_step_error;
                min_frame <=> root.min_frame;
                max_frame <=> root.max_frame;
                min_frame_error: root.min_frame_error;
                max_frame_error: root.max_frame_error;
                opacity: (root.file_loaded && root.num_frames > 1) ? 1.0 : 0.5;
            }
        }

        // 2. Middle column: Options Tabbed Card (Setup, Trajectory, Parameters, Export)
            Rectangle {
            width: 340px;
            horizontal-stretch: 0;

            options_container := Vertical {
                width: 100%;
                height: 100%;
                padding: 0;
                opacity: root.file_loaded ? 1.0 : 0.5;
                animate opacity { duration: 150ms; }

                // TAB NAVIGATION BAR (3 tabs)
                    property <int> active_tab: 0;
                Horizontal {
                    height: 40px;
                    spacing: 4px;
                    padding-bottom: 4px;

                    TabItem {
                        text: "Common";
                        active: options_container.active_tab == 0;
                        clicked => { options_container.active_tab = 0; }
                    }

                    TabItem {
                        text: "Advanced";
                        active: options_container.active_tab == 1;
                        clicked => { options_container.active_tab = 1; }
                    }

                    TabItem {
                        text: "Distribution";
                        active: options_container.active_tab == 2;
                        clicked => { options_container.active_tab = 2; }
                    }
                }

                property <string> local_tooltip: 
                        (options_container.active_tab == 2 && analyses_card.hovered_calculator_description != "") ? analyses_card.hovered_calculator_description :
                    (options_container.active_tab == 1 && sq_card.hovered_tooltip_text != "") ? sq_card.hovered_tooltip_text :
                    (options_container.active_tab == 1 && rings_card.hovered_tooltip_text != "") ? rings_card.hovered_tooltip_text :
                    (options_container.active_tab == 1 && smoothing_card.hovered_tooltip_text != "") ? smoothing_card.hovered_tooltip_text :
                    (options_container.active_tab == 0 && material_card.hovered_tooltip_text != "") ? material_card.hovered_tooltip_text :
                    (options_container.active_tab == 0 && rdf_card.hovered_tooltip_text != "") ? rdf_card.hovered_tooltip_text :
                    (options_container.active_tab == 0 && angle_card.hovered_tooltip_text != "") ? angle_card.hovered_tooltip_text : "";

                property <length> local_hovered_x:
                        (options_container.active_tab == 2 && analyses_card.hovered_calculator_description != "") ? analyses_card.hovered_x :
                    (options_container.active_tab == 1 && sq_card.hovered_tooltip_text != "") ? sq_card.hovered_x :
                    (options_container.active_tab == 1 && rings_card.hovered_tooltip_text != "") ? rings_card.hovered_x :
                    (options_container.active_tab == 1 && smoothing_card.hovered_tooltip_text != "") ? smoothing_card.hovered_x :
                    (options_container.active_tab == 0 && material_card.hovered_tooltip_text != "") ? material_card.hovered_x :
                    (options_container.active_tab == 0 && rdf_card.hovered_tooltip_text != "") ? rdf_card.hovered_x :
                    (options_container.active_tab == 0 && angle_card.hovered_tooltip_text != "") ? angle_card.hovered_x : 0px;

                property <length> local_hovered_y:
                        (options_container.active_tab == 2 && analyses_card.hovered_calculator_description != "") ? analyses_card.hovered_y :
                    (options_container.active_tab == 1 && sq_card.hovered_tooltip_text != "") ? sq_card.hovered_y :
                    (options_container.active_tab == 1 && rings_card.hovered_tooltip_text != "") ? rings_card.hovered_y :
                    (options_container.active_tab == 1 && smoothing_card.hovered_tooltip_text != "") ? smoothing_card.hovered_y :
                    (options_container.active_tab == 0 && material_card.hovered_tooltip_text != "") ? material_card.hovered_y :
                    (options_container.active_tab == 0 && rdf_card.hovered_tooltip_text != "") ? rdf_card.hovered_y :
                    (options_container.active_tab == 0 && angle_card.hovered_tooltip_text != "") ? angle_card.hovered_y : 0px;

                property <length> local_hovered_width:
                        (options_container.active_tab == 2 && analyses_card.hovered_calculator_description != "") ? analyses_card.hovered_width :
                    (options_container.active_tab == 1 && sq_card.hovered_tooltip_text != "") ? sq_card.hovered_width :
                    (options_container.active_tab == 1 && rings_card.hovered_tooltip_text != "") ? rings_card.hovered_width :
                    (options_container.active_tab == 1 && smoothing_card.hovered_tooltip_text != "") ? smoothing_card.hovered_width :
                    (options_container.active_tab == 0 && material_card.hovered_tooltip_text != "") ? material_card.hovered_width :
                    (options_container.active_tab == 0 && rdf_card.hovered_tooltip_text != "") ? rdf_card.hovered_width :
                    (options_container.active_tab == 0 && angle_card.hovered_tooltip_text != "") ? angle_card.hovered_width : 0px;

                property <length> local_hovered_height:
                        (options_container.active_tab == 2 && analyses_card.hovered_calculator_description != "") ? analyses_card.hovered_height :
                    (options_container.active_tab == 1 && sq_card.hovered_tooltip_text != "") ? sq_card.hovered_height :
                    (options_container.active_tab == 1 && rings_card.hovered_tooltip_text != "") ? rings_card.hovered_height :
                    (options_container.active_tab == 1 && smoothing_card.hovered_tooltip_text != "") ? smoothing_card.hovered_height :
                    (options_container.active_tab == 0 && material_card.hovered_tooltip_text != "") ? material_card.hovered_height :
                    (options_container.active_tab == 0 && rdf_card.hovered_tooltip_text != "") ? rdf_card.hovered_height :
                    (options_container.active_tab == 0 && angle_card.hovered_tooltip_text != "") ? angle_card.hovered_height : 0px;

                changed local_tooltip => {
                    root.options_hovered_tooltip = self.local_tooltip;
                }

                ScrollView {
                    viewport-height: options_layout.preferred-height;
                    options_layout := Vertical {
                        padding: 0;
                        spacing: MaterialStyleMetrics.spacing_4;

                        // Common Tab Options (Material Type, Bond Cutoffs, RDF, Angular)
                            material_card := MaterialTypeCard {
                            file_loaded: root.file_loaded;
                            material_type <=> root.material_type;
                            visible: options_container.active_tab == 0;
                            height: options_container.active_tab == 0 ? self.preferred-height : 0px;
                        }

                        bond_cutoffs_card := BondCutoffsCard {
                            file_loaded: root.file_loaded;
                            bond_cutoffs <=> root.bond_cutoffs;
                            atom_counts: root.atom_counts;
                            visible: options_container.active_tab == 0;
                            height: options_container.active_tab == 0 ? self.preferred-height : 0px;
                        }

                        rdf_card := RDFOptionsCard {
                            file_loaded: root.file_loaded;
                            r_max <=> root.r_max;
                            r_bin_width <=> root.r_bin_width;
                            r_max_error: root.r_max_error;
                            r_bin_error: root.r_bin_error;
                            visible: options_container.active_tab == 0 && root.has_radial_active;
                            height: (options_container.active_tab == 0 && root.has_radial_active) ? self.preferred-height : 0px;
                        }

                        angle_card := BondAngleOptionsCard {
                            file_loaded: root.file_loaded;
                            angle_bin_width <=> root.angle_bin_width;
                            dihedral_bin_width <=> root.dihedral_bin_width;
                            angle_bin_error: root.angle_bin_error;
                            dihedral_bin_error: root.dihedral_bin_error;
                            visible: options_container.active_tab == 0 && root.has_angular_active;
                            height: (options_container.active_tab == 0 && root.has_angular_active) ? self.preferred-height : 0px;
                        }

                        // Advanced Tab Options (SQ, Rings, Smoothing)
                            sq_card := SQOptionsCard {
                            file_loaded: root.file_loaded;
                            q_max <=> root.q_max;
                            q_bin_width <=> root.q_bin_width;
                            r_int_max <=> root.r_int_max;
                            q_max_error: root.q_max_error;
                            q_bin_error: root.q_bin_error;
                            r_int_max_error: root.r_int_max_error;
                            visible: options_container.active_tab == 1 && root.has_scattering_active;
                            height: (options_container.active_tab == 1 && root.has_scattering_active) ? self.preferred-height : 0px;
                        }

                        rings_card := RingsOptionsCard {
                            file_loaded: root.file_loaded;
                            max_ring_size <=> root.max_ring_size;
                            max_ring_error: root.max_ring_error;
                            visible: options_container.active_tab == 1 && root.has_rings_active;
                            height: (options_container.active_tab == 1 && root.has_rings_active) ? self.preferred-height : 0px;
                        }

                        smoothing_card := SmoothingOptionsCard {
                            file_loaded: root.file_loaded;
                            smoothing_enabled <=> root.smoothing;
                            smoothing_sigma <=> root.smoothing_sigma;
                            smoothing_kernel <=> root.smoothing_kernel;
                            smoothing_sigma_error: root.smoothing_sigma_error;
                            visible: options_container.active_tab == 1;
                            height: options_container.active_tab == 1 ? self.preferred-height : 0px;
                        }

                        // Distribution Tab Options (Calculator Selections)
                            analyses_card := AnalysesSelectionCard {
                            file_loaded: root.file_loaded;
                            calculator_groups: root.calculator_groups;
                            total_calculator_count: root.total_calculator_count;
                            toggle_calculator(id, enabled) => {
                                root.toggle_calculator(id, enabled);
                            }
                            visible: options_container.active_tab == 2;
                            height: options_container.active_tab == 2 ? self.preferred-height : 0px;
                        }
                    }
                }
            }

            // Block interactions if not file_loaded
                if !root.file_loaded: TouchArea {
                width: 100%;
                height: 100%;
            }
        }

        // 3. Right column: Visual Preview Card (stretches to fill remaining space)
            Rectangle {
            horizontal-stretch: 1;

            Vertical {
                width: 100%;
                height: 100%;
                padding: 0;
                opacity: root.analysis_done ? 1.0 : 0.5;
                animate opacity { duration: 150ms; }

                preview_card := PreviewCard {
                    vertical-stretch: 1;
                    horizontal-stretch: 1;
                    preview_plot <=> root.preview_plot;
                    plot_items <=> root.plot_items;
                    selected_plot_index <=> root.selected_plot_index;
                    pinned_runs_count: root.pinned_runs_count;

                    export_size_preset <=> root.export_size_preset;
                    export_palette <=> root.export_palette;
                    export_font_scale <=> root.export_font_scale;
                    export_line_width <=> root.export_line_width;
                    export_show_legend <=> root.export_show_legend;
                    export_show_grid <=> root.export_show_grid;
                    export_show_markers <=> root.export_show_markers;
                    export_fill_area <=> root.export_fill_area;
                    export_font_scale_error: root.export_font_scale_error;
                    export_line_width_error: root.export_line_width_error;

                    plot_selected(idx) => {
                        root.select_plot(idx);
                    }
                    save_plot => {
                        root.save_plot();
                    }
                    pin_run => {
                        root.pin_run();
                    }
                    clear_pinned_runs => {
                        root.clear_pinned_runs();
                    }
                    mouse_move(mx, my, hover, w, h) => {
                        root.mouse_move(mx, my, hover, w, h);
                    }
                    plot_resized(w, h) => {
                        root.plot_resized(w, h);
                    }
                }
            }

            // Block interactions if not analysis_done
                if !root.analysis_done: TouchArea {
                width: 100%;
                height: 100%;
            }
        }
    }

    AppToolTips {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;
        hovered_x: root.hovered_x;
        hovered_y: root.hovered_y;
        hovered_width: root.hovered_width;
        hovered_height: root.hovered_height;
        hovered_tooltip_text: root.hovered_tooltip_text;
    }
}
