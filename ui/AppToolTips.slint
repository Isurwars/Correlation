import { ToolTip } from "material/material.slint";

// ============================================================================
// AppToolTips Component
// ============================================================================
/// This component manages all tooltips displayed across the application.
/// 
/// C++ Binding Architecture:
/// - This component does not directly interface with the C++ backend.
/// - Instead, it relies on hover states (e.g., `file_hover`, `r_max_hover`)
///   passed down from the parent `AppWindow` and its child components. 
/// - It acts purely as a presentation layer for UI hints.
// ============================================================================
export component AppToolTips inherits Rectangle {
    in property <length> mouse_x;
    in property <length> mouse_y;
    background: transparent;
    
    // Hover text to display
    in property <string> hovered_tooltip_text: "";

    ToolTip {
        mouse_x: root.mouse_x;
        mouse_y: root.mouse_y;
        parent_width: root.width;
        parent_height: root.height;
        visible: root.hovered_tooltip_text != "";
        text: root.hovered_tooltip_text;
    }
}
