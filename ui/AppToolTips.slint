import { ToolTip } from "@material";

export component AppToolTips inherits Rectangle {
    in property <length> mouse_x;
    in property <length> mouse_y;
    background: transparent;
    
    // Hover states for each tooltip
    in property <bool> file_hover;
    in property <bool> r_max_hover;
    in property <bool> r_bin_hover;
    in property <bool> q_max_hover;
    in property <bool> theta_bin_hover;
    in property <bool> q_bin_hover;
    in property <bool> r_int_hover;

    in property <bool> sigma_hover;
    in property <bool> kernel_hover;
    in property <bool> hdf5_hover;
    in property <bool> csv_hover;
    in property <bool> frames_hover;
    in property <bool> atoms_hover;
    in property <bool> removed_frames_hover;
    in property <bool> time_step_hover;
    in property <bool> dihedral_bin_hover;
    in property <bool> ring_size_hover;
    in property <bool> rdf_cb_hover;
    in property <bool> sq_cb_hover;
    in property <bool> xrd_cb_hover;
    in property <bool> pad_cb_hover;
    in property <bool> dad_cb_hover;
    in property <bool> md_cb_hover;
    in property <bool> vacf_cb_hover;
    in property <bool> vdos_cb_hover;

    in property <bool> options_area_hover;
    in property <bool> start_frame_hover;
    in property <bool> end_frame_hover;
    in property <bool> analysis_area_hover;
    in property <bool> write_area_hover;

    ToolTip {
        mouse_x: root.mouse_x;
        mouse_y: root.mouse_y;
        parent_width: root.width;
        parent_height: root.height;
        visible: file_hover || hdf5_hover || csv_hover || r_max_hover || r_bin_hover || q_max_hover || theta_bin_hover || q_bin_hover || r_int_hover || sigma_hover || kernel_hover || dihedral_bin_hover || ring_size_hover || rdf_cb_hover || sq_cb_hover || xrd_cb_hover || pad_cb_hover || dad_cb_hover || md_cb_hover || vacf_cb_hover || vdos_cb_hover || frames_hover || atoms_hover || removed_frames_hover || time_step_hover || options_area_hover || start_frame_hover || end_frame_hover || analysis_area_hover || write_area_hover;
        text: file_hover ? "Load a structure file" : hdf5_hover ? "If enabled, the results will be exported to a single HDF5 file." : csv_hover ? "If enabled, the results will be exported as CSV files." : r_max_hover ? "Maximum radius to calculate Radial Distribution Functions (g(r), J(r), G(r)). The recommended max radius is 20 Å." : r_bin_hover ? "Bin width used to calculate the histograms for the Radial Distribution Functions (g(r), J(r), G(r)). The recommended bin is 0.02 Å." : q_max_hover ? "Maximum scattering vector (Q) to calculate the Structure Factor (S(Q)). The recommended max scattering vector is 20.0 Å⁻¹" : theta_bin_hover ? "Bin width used to calculate the histograms for the Plane-Angle Distribution. The recommended bin is 1.0°." : q_bin_hover ? "Bin width used to calculate the histograms for the Structure Factor. The recommended bin is 0.02 Å⁻¹." : r_int_hover ? "Maximum radius for the Fourier Transform of the g(r) used to calculate the Structure Factor. The recommended max radius is 10.0 Å" : sigma_hover ? "Sigma to be used for the smoothing of the distribution functions. The recommended  sigma is 0.01." : kernel_hover ? "The kernel used by the kernel smoother. The recommended kernel is the Gaussian kernel." : dihedral_bin_hover ? "Bin width used to calculate the histograms for the Dihedral-Angle Distribution. The recommended bin is 1.0°." : ring_size_hover ? "Maximum ring size to search for in topological motif analysis." : rdf_cb_hover ? "Enable calculation of Radial Distribution Functions: g(r), J(r), and G(r)." : sq_cb_hover ? "Enable calculation of the Structure Factor S(Q)." : xrd_cb_hover ? "Enable calculation of the X-Ray Diffraction pattern (XRD)." : pad_cb_hover ? "Enable calculation of the Plane-Angle Distribution (PAD)." : dad_cb_hover ? "Enable calculation of the Dihedral-Angle Distribution (DAD)." : md_cb_hover ? "Enable search for Topological Motif Rings." : vacf_cb_hover ? "Enable calculation of the Velocity Autocorrelation Function (VACF)." : vdos_cb_hover ? "Enable calculation of the Vibrational Density of States (vDoS)." : frames_hover ? "Number of structural frames parsed from the file." : atoms_hover ? "Total number of atoms found in a single frame." : removed_frames_hover ? "Number of frames skipped due to parsing errors or missing structural data." : time_step_hover ? "Time interval between parsed frames in femtoseconds (fs). Useful for dynamic calculations." : options_area_hover ? "Toggle advanced analysis options." : start_frame_hover ? "First frame to include in the analysis." : end_frame_hover ? "Last frame to include in the analysis (use 'End' for the final frame)." : analysis_area_hover ? "Start the selected analyses." : write_area_hover ? "Export the analysis results to files." : "";
    }
}
