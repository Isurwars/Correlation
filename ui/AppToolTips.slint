import { ToolTip } from "@material";

export component AppToolTips inherits Rectangle {
    in property <length> mouse_x;
    in property <length> mouse_y;
    background: transparent;
    
    // Hover states for each tooltip
    in property <bool> file_hover;
    in property <bool> r_max_hover;
    in property <bool> r_bin_hover;
    in property <bool> q_max_hover;
    in property <bool> theta_bin_hover;
    in property <bool> q_bin_hover;
    in property <bool> r_int_hover;

    in property <bool> sigma_hover;
    in property <bool> kernel_hover;
    in property <bool> hdf5_hover;
    in property <bool> csv_hover;
    in property <bool> dihedral_bin_hover;
    in property <bool> ring_size_hover;
    in property <bool> rdf_cb_hover;
    in property <bool> sq_cb_hover;
    in property <bool> xrd_cb_hover;
    in property <bool> pad_cb_hover;
    in property <bool> dad_cb_hover;
    in property <bool> md_cb_hover;
    in property <bool> vacf_cb_hover;
    in property <bool> vdos_cb_hover;

    in property <bool> options_area_hover;
    in property <bool> start_frame_hover;
    in property <bool> end_frame_hover;
    in property <bool> analysis_area_hover;
    in property <bool> write_area_hover;

    ToolTip {
        x: mouse_x + 20px;
        y: mouse_y + 20px;
        text: "Load a structure file";
        visible: file_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "If enabled, the results will be exported to a single HDF5 file.";
        visible: hdf5_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "If enabled, the results will be exported as CSV files.";
        visible: csv_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Maximum radius to calculate Radial Distribution Functions (g(r), J(r), G(r)). The recommended max radius is 20 Å.";
        visible: r_max_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Bin width used to calculate the histograms for the Radial Distribution Functions (g(r), J(r), G(r)). The recommended bin is 0.02 Å.";
        visible: r_bin_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Maximum scattering vector (Q) to calculate the Structure Factor (S(Q)). The recommended max scattering vector is 20.0 Å⁻¹";
        visible: q_max_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Bin width used to calculate the histograms for the Plane-Angle Distribution. The recommended bin is 1.0°.";
        visible: theta_bin_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Bin width used to calculate the histograms for the Structure Factor. The recommended bin is 0.02 Å⁻¹.";
        visible: q_bin_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Maximum radius for the Fourier Transform of the g(r) used to calculate the Structure Factor. The recommended max radius is 10.0 Å";
        visible: r_int_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Sigma to be used for the smoothing of the distribution functions. The recommended  sigma is 0.01.";
        visible: sigma_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "The kernel used by the kernel smoother. The recommended kernel is the Gaussian kernel.";
        visible: kernel_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Bin width used to calculate the histograms for the Dihedral-Angle Distribution. The recommended bin is 1.0°.";
        visible: dihedral_bin_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Maximum ring size to search for in topological motif analysis.";
        visible: ring_size_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Enable calculation of Radial Distribution Functions: g(r), J(r), and G(r).";
        visible: rdf_cb_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Enable calculation of the Structure Factor S(Q).";
        visible: sq_cb_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Enable calculation of the X-Ray Diffraction pattern (XRD).";
        visible: xrd_cb_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Enable calculation of the Plane-Angle Distribution (PAD).";
        visible: pad_cb_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Enable calculation of the Dihedral-Angle Distribution (DAD).";
        visible: dad_cb_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Enable search for Topological Motif Rings.";
        visible: md_cb_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Enable calculation of the Velocity Autocorrelation Function (VACF).";
        visible: vacf_cb_hover;
    }

    ToolTip {
        x: mouse_x - 240px;
        y: mouse_y + 20px;
        text: "Enable calculation of the Vibrational Density of States (vDoS).";
        visible: vdos_cb_hover;
    }

    ToolTip {
        x: mouse_x + 20px;
        y: mouse_y + 20px;
        text: "Toggle advanced analysis options.";
        visible: options_area_hover;
    }

    ToolTip {
        x: mouse_x + 20px;
        y: mouse_y + 20px;
        text: "First frame to include in the analysis.";
        visible: start_frame_hover;
    }

    ToolTip {
        x: mouse_x + 20px;
        y: mouse_y + 20px;
        text: "Last frame to include in the analysis (use 'End' for the final frame).";
        visible: end_frame_hover;
    }

    ToolTip {
        x: mouse_x + 20px;
        y: mouse_y + 20px;
        text: "Start the selected analyses.";
        visible: analysis_area_hover;
    }

    ToolTip {
        x: mouse_x + 20px;
        y: mouse_y + 20px;
        text: "Export the analysis results to files.";
        visible: write_area_hover;
    }
}
