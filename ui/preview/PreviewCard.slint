import {
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialTypography,
    FilledCard,
    MaterialText,
    DropDownMenu,
    MenuItem,
    Vertical,
    FilledButton,
    Horizontal,
    Icons,
    InfoRow,
    ScrollView,
    TabItem,
} from "../material/material.slint";
import { ExportSettingsCard } from "ExportSettingsCard.slint";
import { TableRow } from "../Types.slint";

// ============================================================================

// ============================================================================
// PreviewCard Component
// ============================================================================
/// Displays a preview plot of a computed distribution function as a static SVG
/// image. The rendered image is produced by the C++ backend (`AppController`)
/// using the `SvgPlotter` utility and pushed via `preview_plot`.
///
/// C++ Binding Architecture:
/// - `plot_items`: populated after analysis finishes with histogram names as
///   MenuItem structs (e.g., {text: "g(r)", enabled: true}).
///   The C++ controller builds a VectorModel<MenuItem> from the DF histogram
///   keys and pushes it via `ui.set_plot_items(model)`.
/// - `preview_plot`: an `slint::Image` produced from an SVG string by
///   `slint::Image::load_from_svg_data()` in the controller.
/// - `plot_selected(index)`: callback invoked when the user changes the dropdown;
/// - `plot_items`: A list of menu items containing descriptive titles
/// - `selected_plot_index`: The index of the currently active diagram.
/// - `preview_plot`: The current generated plot image.
// ============================================================================
export component PreviewCard inherits FilledCard {
    in property <image> preview_plot;
    in property <[MenuItem]> plot_items: [];
    in-out property <int> selected_plot_index: -1;
    in property <int> pinned_runs_count: 0;

    // Table data and calculated scalar properties
    in property <[string]> table_headers: [];
    in property <[TableRow]> table_rows: [];
    in property <string> diff_msd: "";
    in property <string> diff_vacf: "";
    in property <string> relaxation_time: "";
    in property <string> deborah_number: "";

    property <int> active_tab: 0;

    in-out property <int> export_size_preset: 0;
    in-out property <int> export_palette: 0;
    in-out property <string> export_font_scale: "1.0";
    in-out property <string> export_line_width: "3.0";
    in-out property <bool> export_show_legend: true;
    in-out property <bool> export_show_grid: true;
    in-out property <bool> export_show_markers: false;
    in-out property <bool> export_fill_area: false;

    in property <string> export_font_scale_error: "";
    in property <string> export_line_width_error: "";

    callback plot_selected(int);
    callback save_plot();
    callback pin_run();
    callback clear_pinned_runs();
    callback mouse_move(length, length, bool, length, length);
    callback plot_resized(length, length);

    // Hover state for tooltip
    out property <string> hovered_tooltip_text:
        plot_dropdown_area.has-hover ? "Select a distribution function to preview.\n\n💡 Tip: Use 'Pin Run' to save the current results, then adjust parameters and re-run. Pinned runs overlay on the plot for direct visual comparison — great for seeing how parameter changes affect your results." : export_settings.hovered_tooltip_text != "" ? export_settings.hovered_tooltip_text : "";

    out property <length> hovered_x:
        plot_dropdown_area.has-hover ? plot_dropdown_area.absolute-position.x :
        export_settings.hovered_tooltip_text != "" ? export_settings.hovered_x : 0px;
    out property <length> hovered_y:
        plot_dropdown_area.has-hover ? plot_dropdown_area.absolute-position.y :
        export_settings.hovered_tooltip_text != "" ? export_settings.hovered_y : 0px;
    out property <length> hovered_width:
        plot_dropdown_area.has-hover ? plot_dropdown_area.width :
        export_settings.hovered_tooltip_text != "" ? export_settings.hovered_width : 0px;
    out property <length> hovered_height:
        plot_dropdown_area.has-hover ? plot_dropdown_area.height :
        export_settings.hovered_tooltip_text != "" ? export_settings.hovered_height : 0px;

    Vertical {
        spacing: MaterialStyleMetrics.spacing_8;

        // Header and Tabs row
        Horizontal {
            alignment: center;
            
            // Tab Buttons
            Horizontal {
                spacing: 8px;
                TabItem {
                    text: "Plot";
                    active: root.active_tab == 0;
                    clicked => { root.active_tab = 0; }
                }
                TabItem {
                    text: "Data & Stats";
                    active: root.active_tab == 1;
                    clicked => { root.active_tab = 1; }
                }
            }
        }

        // Plot selector dropdown and Save Plot button
        Horizontal {
            spacing: MaterialStyleMetrics.spacing_8;
            height: MaterialStyleMetrics.size_40;
            
            plot_dropdown_area := TouchArea {
                horizontal-stretch: 1;
                DropDownMenu {
                    width: 100%;
                    height: 100%;
                    label: "Select Plot";
                    enabled: root.plot_items.length > 0;
                    items: root.plot_items;
                    current_index <=> root.selected_plot_index;

                    selected(idx) => {
                        root.plot_selected(idx);
                    }
                }
            }

            // Save Button
            FilledButton {
                text: "Save Plot";
                icon: Icons.save;
                enabled: root.selected_plot_index >= 0;
                clicked => {
                    root.save_plot();
                }
            }
        }

        // Pinned Runs Info
        if root.pinned_runs_count > 0: Horizontal {
            spacing: MaterialStyleMetrics.spacing_8;
            height: MaterialStyleMetrics.size_40;
            MaterialText {
                text: "Comparing with " + root.pinned_runs_count + " pinned run(s)";
                color: MaterialPalette.on_surface_variant;
                vertical-alignment: center;
            }
            FilledButton {
                text: "Clear Pinned";
                clicked => { root.clear_pinned_runs(); }
            }
        }

        // Tab Content Switcher
        if root.active_tab == 0: Vertical {
            vertical-stretch: 1;
            spacing: MaterialStyleMetrics.spacing_8;

            // SVG plot image area — fills remaining space
            plot_container := Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: MaterialPalette.surface;
                border-radius: MaterialStyleMetrics.border_radius_2;
                clip: self.width > 1px && self.height > 1px;
                visible: self.width > 0.1px && self.height > 0.1px;

                changed width => {
                    root.plot_resized(self.width, self.height);
                }
                changed height => {
                    root.plot_resized(self.width, self.height);
                }

                // Placeholder text when no image is available
                if root.selected_plot_index < 0: Vertical {
                    padding: MaterialStyleMetrics.spacing_8;
                    MaterialText {
                        text: "Select a plot from the dropdown above.";
                        color: MaterialPalette.on_surface_variant;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        wrap: word-wrap;
                    }
                }

                // The rendered SVG plot
                plot_touch := TouchArea {
                    width: 100%;
                    height: 100%;
                    visible: root.selected_plot_index >= 0;

                    changed has-hover => {
                        root.mouse_move(self.mouse-x, self.mouse-y, self.has-hover, self.width, self.height);
                    }

                    changed mouse-x => {
                        root.mouse_move(self.mouse-x, self.mouse-y, self.has-hover, self.width, self.height);
                    }

                    Image {
                        width: 100%;
                        height: 100%;
                        source: root.preview_plot;
                        image-fit: contain;
                    }
                }
            }
        }

        export_settings := ExportSettingsCard {
            visible: root.active_tab == 0;
            height: root.active_tab == 0 ? self.preferred-height : 0px;
            enabled: root.selected_plot_index >= 0;
            export_size_preset <=> root.export_size_preset;
            export_palette <=> root.export_palette;
            export_font_scale <=> root.export_font_scale;
            export_line_width <=> root.export_line_width;
            export_show_legend <=> root.export_show_legend;
            export_show_grid <=> root.export_show_grid;
            export_show_markers <=> root.export_show_markers;
            export_fill_area <=> root.export_fill_area;
            export_font_scale_error: root.export_font_scale_error;
            export_line_width_error: root.export_line_width_error;
        }

        if root.active_tab == 1: Vertical {
            vertical-stretch: 1;
            spacing: MaterialStyleMetrics.spacing_12;

            // Calculated Dynamic Properties
            if (root.diff_msd != "" || root.diff_vacf != "" || root.relaxation_time != "" || root.deborah_number != "") : Vertical {
                spacing: MaterialStyleMetrics.spacing_4;

                MaterialText {
                    text: "Calculated Dynamic Properties";
                    style: MaterialTypography.title_small;
                    color: MaterialPalette.on_surface;
                }

                Rectangle {
                    background: MaterialPalette.surface_container_low;
                    border-radius: MaterialStyleMetrics.border_radius_2;
                    border-width: 1px;
                    border-color: MaterialPalette.outline_variant;

                    VerticalLayout {
                        padding: MaterialStyleMetrics.spacing_8;
                        spacing: MaterialStyleMetrics.spacing_8;

                        if root.diff_msd != "" : InfoRow {
                            label: "Self-diffusion coefficient (from MSD)";
                            value: root.diff_msd;
                        }
                        if root.diff_vacf != "" : InfoRow {
                            label: "Self-diffusion coefficient (from VACF)";
                            value: root.diff_vacf;
                        }
                        if root.relaxation_time != "" : InfoRow {
                            label: "Relaxation time (from VACF)";
                            value: root.relaxation_time;
                        }
                        if root.deborah_number != "" : InfoRow {
                            label: "Deborah number";
                            value: root.deborah_number;
                        }
                    }
                }
            }

            // Dataset Values Table
            Vertical {
                vertical-stretch: 1;
                spacing: MaterialStyleMetrics.spacing_4;

                MaterialText {
                    text: "Dataset Values";
                    style: MaterialTypography.title_small;
                    color: MaterialPalette.on_surface;
                }

                if root.table_rows.length == 0 : Rectangle {
                    vertical-stretch: 1;
                    background: MaterialPalette.surface;
                    border-radius: MaterialStyleMetrics.border_radius_2;
                    border-width: 1px;
                    border-color: MaterialPalette.outline_variant;

                    MaterialText {
                        text: "No dataset values available.";
                        color: MaterialPalette.on_surface_variant;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if root.table_rows.length > 0 : Rectangle {
                    vertical-stretch: 1;
                    background: MaterialPalette.surface;
                    border-radius: MaterialStyleMetrics.border_radius_2;
                    border-width: 1px;
                    border-color: MaterialPalette.outline_variant;
                    clip: true;

                    VerticalLayout {
                        padding: 1px;

                        // Header Row
                        Rectangle {
                            background: MaterialPalette.surface_container_high;
                            height: 36px;
                            
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                for header_text in root.table_headers : Vertical {
                                    alignment: center;
                                    MaterialText {
                                        text: header_text;
                                        style: MaterialTypography.label_medium;
                                        font_weight: MaterialTypography.semibold;
                                        color: MaterialPalette.on_surface;
                                    }
                                }
                            }
                        }

                        // Divider line
                        Rectangle {
                            height: 1px;
                            background: MaterialPalette.outline_variant;
                        }

                        // Scrollable Rows
                        ScrollView {
                            viewport-height: root.table_rows.length * 32px;

                            VerticalLayout {
                                for row[row_idx] in root.table_rows : Rectangle {
                                    height: 32px;

                                    VerticalLayout {
                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            spacing: 8px;
                                            for val in row.values : Vertical {
                                                alignment: center;
                                                MaterialText {
                                                    text: val;
                                                    style: MaterialTypography.body_medium;
                                                    color: MaterialPalette.on_surface;
                                                }
                                            }
                                        }

                                        // Divider line between rows
                                        Rectangle {
                                            height: 1px;
                                            background: MaterialPalette.outline_variant.with_alpha(15%);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

